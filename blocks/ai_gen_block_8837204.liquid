{% doc %}
  @prompt
    Give me a section that helps me render snippets.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-snippet-renderer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-snippet-renderer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-snippet-renderer-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-snippet-renderer-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-snippet-renderer-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-snippet-renderer-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-snippet-renderer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-snippet-renderer-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-snippet-renderer-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-snippet-renderer-content-{{ ai_gen_id }}">
      {% if block.settings.snippet_name != blank %}
        {% render block.settings.snippet_name %}
      {% else %}
        <div style="padding: 40px; text-align: center; background-color: #f9fafb; border: 2px dashed #d1d5db; border-radius: 8px; color: #6b7280;">
          <p style="margin: 0; font-size: 14px;">Enter a snippet name to render it here</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Snippet renderer",
  "settings": [
    {
      "type": "header",
      "content": "Snippet"
    },
    {
      "type": "text",
      "id": "snippet_name",
      "label": "Snippet file name",
      "info": "Enter the snippet file name without .liquid extension (e.g., 'custom-banner')"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Heading bottom spacing",
      "default": 24
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Snippet renderer"
    }
  ]
}
{% endschema %}
