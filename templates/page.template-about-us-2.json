e in India, Made for the World","text":"We proudly support local artisans and communities while delivering world-class designs loved by parents globally."}},"value_item_6J9WPj":{"type":"value_item","name":"4","settings":{"pill":"04","title":"Style That Celebrates Childhood","text":"From festive occasions to everyday wear, we bring playful, elegant, and trend-right styles that make kids look and feel special."}},"value_item_KcdGUh":{"type":"value_item","name":"5","settings":{"pill":"05","title":"Thoughtful Sustainability","text":"We care for the planet our kids will inherit — by choosing better materials, reducing waste, and making conscious production choices."}},"value_item_tQVzVL":{"type":"value_item","name":"6","settings":{"pill":"06","title":"Parents’ Trusted Partner","text":"Shopping with us is simple, safe, and stress-free — we stand by our customers with easy returns, transparent policies, and reliable service."}}},"block_order":["banner_solid_nEhfDJ","about_CE7HKw","mission_vision_J6VgBr","values_KY7PcJ","value_item_PUHKDj","value_item_WrrNWh","value_item_AfntjF","value_item_6J9WPj","value_item_KcdGUh","value_item_tQVzVL"],"name":"Lagorii — About Us","settings":{"heading_font":"montserrat_n6","body_font":"montserrat_n4","base_font_size":16,"h1_size":44,"h2_size":32,"h3_size":22,"heading_letter_spacing":0,"line_height":"1.7","max_width":1440,"section_padding_desktop":64,"section_padding_x_desktop":24,"section_padding_mobile":20,"section_padding_x_mobile":12,"block_gap":44,"brand_color":"#e87529","text_color":"#1a1a1a","muted_color":"#6b7280","bg_color":"#ffffff","radius":15,"card_bg":"#ffffff","card_border":"#f0f0f0","card_pad":12,"split_gap":22,"split_text_col":1,"split_image_col":1,"split_img_h":380,"split_img_fit":"cover","mv_gap":28,"values_cols_desktop":3,"values_cols_mobile":2,"values_gap":18,"values_pad_desktop":18,"values_pad_mobile":14,"values_min_h_desktop":140,"values_min_h_mobile":120,"timeline_line":"#eeeeee","timeline_gap":20,"team_cols_desktop"