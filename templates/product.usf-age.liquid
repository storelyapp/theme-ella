{% layout none %}
{% comment %}
    Renders a product card

    Accepts:
    - product: {Object} Product Liquid object (optional)
    - media_size: {String} Size of the product image card. Values are "square" and "portrait". Default is "square" (optional)
    - show_secondary_image: {Boolean} Show the secondary image on hover. Default: false (optional)
    - add_image_padding: {Boolean} Enables padding on the image to space out the grid
    - show_vendor: {Boolean} Show the product vendor. Default: false

    Usage:
    {% render 'product-card', show_vendor: section.settings.show_vendor %}
{% endcomment %}

{%- liquid
    assign pc02_age_btn_enable = settings.pc02_age_btn_enable | default: true
    assign pc02_age_metafield_key = settings.pc02_age_metafield_key | default: 'custom.age'

    assign pc02_age_meta = blank
    if pc02_age_metafield_key != blank and pc02_age_metafield_key contains '.'
      assign pc02_age_ns = pc02_age_metafield_key | split: '.' | first
      assign pc02_age_key = pc02_age_metafield_key | split: '.' | last
      assign pc02_age_meta = product.metafields[pc02_age_ns][pc02_age_key]
    endif
    if pc02_age_meta == blank
      assign pc02_age_meta = product.metafields.custom.age | default: product.metafields.custom.Age | default: product.metafields.custom.ages | default: product.metafields.custom.Ages
    endif

    assign pc02_age_range_text = blank
    assign pc02_show_age_btn = false
    if pc02_age_btn_enable and pc02_age_meta != blank
      assign pc02_age_json = pc02_age_meta.value | default: pc02_age_meta | json
      assign pc02_age_clean = pc02_age_json | replace: '","', '|' | replace: '", "', '|' | replace: '" , "', '|'
      assign pc02_age_clean = pc02_age_clean | replace: '[', '' | replace: ']', '' | replace: '"', ''
      assign pc02_age_clean = pc02_age_clean | replace: '•', '|' | replace: '·', '|' | replace: ',', '|'
      assign pc02_age_clean = pc02_age_clean | replace: '–', '-' | replace: '—', '-' | replace: ' ', ''
      assign pc02_age_list = pc02_age_clean | split: '|'

      assign pc02_has_months = false
      assign pc02_has_years = false
      assign pc02_min_start_months = 999999
      assign pc02_min_start_num = 0
      assign pc02_min_unit = ''
      assign pc02_max_year_lower = 0
      assign pc02_max_year_upper = 0
      assign pc02_max_month_lower = 0
      assign pc02_max_month_upper = 0

      for pc02_token in pc02_age_list
        assign pc02_t = pc02_token | strip
        if pc02_t != blank
          assign pc02_parts = pc02_t | split: '-'
          assign pc02_start_raw = pc02_parts[0]
          assign pc02_end_raw = pc02_start_raw
          if pc02_parts.size > 1
            assign pc02_end_raw = pc02_parts[1]
          endif

          assign pc02_unit = ''
          if pc02_end_raw contains 'M' or pc02_end_raw contains 'm' or pc02_start_raw contains 'M' or pc02_start_raw contains 'm'
            assign pc02_unit = 'M'
            assign pc02_has_months = true
          elsif pc02_end_raw contains 'Y' or pc02_end_raw contains 'y' or pc02_start_raw contains 'Y' or pc02_start_raw contains 'y'
            assign pc02_unit = 'Y'
            assign pc02_has_years = true
          endif

          if pc02_unit != ''
            assign pc02_start_num = pc02_start_raw | remove: 'M' | remove: 'm' | remove: 'Y' | remove: 'y' | plus: 0
            assign pc02_end_num = pc02_end_raw | remove: 'M' | remove: 'm' | remove: 'Y' | remove: 'y' | plus: 0

            assign pc02_start_months = pc02_start_num
            if pc02_unit == 'Y'
              assign pc02_start_months = pc02_start_num | times: 12
            endif

            if pc02_start_months < pc02_min_start_months
              assign pc02_min_start_months = pc02_start_months
              assign pc02_min_start_num = pc02_start_num
              assign pc02_min_unit = pc02_unit
            endif

            if pc02_unit == 'Y'
              if pc02_start_num > pc02_max_year_lower
                assign pc02_max_year_lower = pc02_start_num
              endif
              if pc02_end_num > pc02_max_year_upper
                assign pc02_max_year_upper = pc02_end_num
              endif
            else
              if pc02_start_num > pc02_max_month_lower
                assign pc02_max_month_lower = pc02_start_num
              endif
              if pc02_end_num > pc02_max_month_upper
                assign pc02_max_month_upper = pc02_end_num
              endif
            endif
          endif
        endif
      endfor

      assign pc02_max_unit = ''
      assign pc02_max_num = 0
      if pc02_has_years and pc02_has_months
        assign pc02_max_unit = 'Y'
        assign pc02_max_num = pc02_max_year_upper
      elsif pc02_has_years
        assign pc02_max_unit = 'Y'
        assign pc02_max_num = pc02_max_year_upper
      elsif pc02_has_months
        assign pc02_max_unit = 'M'
        assign pc02_max_num = pc02_max_month_upper
      endif


      if pc02_min_unit != '' and pc02_max_unit != '' and pc02_max_num > 0
        assign pc02_age_range_text = pc02_min_start_num | append: pc02_min_unit | append: ' to ' | append: pc02_max_num | append: pc02_max_unit
        assign pc02_show_age_btn = true
      endif
    endif

-%}

{%- if pc02_show_age_btn -%}
    {{ pc02_age_range_text }}
{%- endif -%}