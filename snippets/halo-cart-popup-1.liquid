    /* --- Ring (SVG) — OUTSIDE the button, centered, with gap --- */
    #halo-add-to-cart-popup .lag-ac-ring{
      display:none !important;
      position:absolute !important;
      left: 50% !important;
      top: 50% !important;

      width: var(--lag-ring-size) !important;
      height: var(--lag-ring-size) !important;

      /* center + start at 12 o’clock */
      transform: translate(-50%, -50%) rotate(-90deg) !important;
      transform-origin: 50% 50% !important;

      pointer-events:none !important;
      overflow: visible !important;
      shape-rendering: geometricPrecision;
    }

    /* IMPORTANT: button must allow ring outside */
    #halo-add-to-cart-popup .lag-atc-action{
      overflow: visible !important;
    }

    #halo-add-to-cart-popup .lag-ac-ring-track{
      fill:none;
      stroke: rgba(255,255,255,0.22);
      stroke-width: var(--lag-ring-w);
      vector-effect: non-scaling-stroke;
    }

    #halo-add-to-cart-popup .lag-ac-ring-prog{
      fill:none;
      stroke: var(--lag-progress-color);
      stroke-width: var(--lag-ring-w);
      stroke-linecap: round;
      vector-effect: non-scaling-stroke;

      /* Using pathLength=100 => easy dash math */
      stroke-dasharray: 100;
      stroke-dashoffset: var(--lag-ac-dash, 100);
    }

    /* show ring only for ring-host */
    #halo-add-to-cart-popup[data-lag-autoclose="1"][data-lag-ac-anim="close_ring"]
