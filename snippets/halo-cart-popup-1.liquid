      display:block !important;
    }

    /* Extra safety to avoid horizontal scroll caused by any fixed children */
    #halo-add-to-cart-popup{
      max-width: calc(100vw - 16px) !important;
    }

    /* Mode-specific tweaks */
    #halo-add-to-cart-popup[data-lag-mode="full"] .product-title{
