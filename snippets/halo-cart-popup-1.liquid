{%- comment -%}
  Lag ATC Popup (snippet, driven by config/settings_schema.json)
  Responsive profiles:
    - Mobile:    *_m   (≤ 767px)
    - Desktop/T: *_d   (≥ 768px)
  Keeps Halo hooks: #halo-add-to-cart-popup, data-add-to-cart-popup, data-close-add-to-cart-popup
{%- endcomment -%}

{%- if settings.lag_atc_enable -%}
  {%- unless settings.show_quick_cart -%}
    <link rel="stylesheet" href="{{ 'component-quick-cart.css' | asset_url }}" media="print" onload="this.media='all'">
  {%- endunless -%}
  <link rel="stylesheet" href="{{ 'component-add-to-cart.css' | asset_url }}" media="print" onload="this.media='all'">

  {%- unless settings.show_quick_cart -%}
    <noscript>{{ 'component-quick-cart.css' | asset_url | stylesheet_tag }}</noscript>
  {%- endunless -%}
  <noscript>{{ 'component-add-to-cart.css' | asset_url | stylesheet_tag }}</noscript>

  {%- liquid
    # -----------------------------
    # Desktop/Tablet computed colors (rgba)
    # -----------------------------
    assign bg_alpha_d = settings.lag_atc_bg_opacity_d | divided_by: 100.0
    assign bg_rgba_d = settings.lag_atc_bg_color_d | color_modify: 'alpha', bg_alpha_d

    assign overlay_alpha_d = settings.lag_atc_progress_overlay_opacity_d | divided_by: 100.0
    assign overlay_rgba_d = settings.lag_atc_progress_overlay_color_d | color_modify: 'alpha', overlay_alpha_d

    assign close_bg_alpha_d = settings.lag_atc_close_bg_opacity_d | divided_by: 100.0
    assign close_bg_rgba_d = settings.lag_atc_close_bg_d | color_modify: 'alpha', close_bg_alpha_d

    assign bd_alpha_d = settings.lag_atc_backdrop_opacity_d | divided_by: 100.0
    assign bd_rgba_d = settings.lag_atc_backdrop_color_d | color_modify: 'alpha', bd_alpha_d

    # -----------------------------
    # Mobile computed colors (rgba)
    # -----------------------------
    assign bg_alpha_m = settings.lag_atc_bg_opacity_m | divided_by: 100.0
    assign bg_rgba_m = settings.lag_atc_bg_color_m | color_modify: 'alpha', bg_alpha_m

    assign overlay_alpha_m = settings.lag_atc_progress_overlay_opacity_m | divided_by: 100.0
    assign overlay_rgba_m = settings.lag_atc_progress_overlay_color_m | color_modify: 'alpha', overlay_alpha_m

    assign close_bg_alpha_m = settings.lag_atc_close_bg_opacity_m | divided_by: 100.0
    assign close_bg_rgba_m = settings.lag_atc_close_bg_m | color_modify: 'alpha', close_bg_alpha_m

    assign bd_alpha_m = settings.lag_atc_backdrop_opacity_m | divided_by: 100.0
    assign bd_rgba_m = settings.lag_atc_backdrop_color_m | color_modify: 'alpha', bd_alpha_m

    # -----------------------------
    # Texts (D/M)
    # -----------------------------
    assign success_msg_d = settings.lag_atc_success_text_d
    if success_msg_d == blank
      assign success_msg_d = 'products.product.add_to_cart_success_message' | t
    endif

    assign success_msg_m = settings.lag_atc_success_text_m
    if success_msg_m == blank
      assign success_msg_m = 'products.product.add_to_cart_success_message' | t
    endif

    assign continue_label_d = settings.lag_atc_continue_label_d
    if continue_label_d == blank
      assign continue_label_d = 'sections.cart.continue_shopping' | t
    endif

    assign continue_label_m = settings.lag_atc_continue_label_m
    if continue_label_m == blank
      assign continue_label_m = 'sections.cart.continue_shopping' | t
    endif

    assign view_cart_label_d = settings.lag_atc_view_cart_label_d
    if view_cart_label_d == blank
      assign view_cart_label_d = 'sections.cart.view_cart' | t
    endif

    assign view_cart_label_m = settings.lag_atc_view_cart_label_m
    if view_cart_label_m == blank
      assign view_cart_label_m = 'sections.cart.view_cart' | t
    endif

    # Fonts
    assign title_font_d = settings.lag_atc_title_font_d
    assign text_font_d  = settings.lag_atc_text_font_d
    assign btn_font_d   = settings.lag_atc_button_font_d

    assign title_font_m = settings.lag_atc_title_font_m
    assign text_font_m  = settings.lag_atc_text_font_m
    assign btn_font_m   = settings.lag_atc_button_font_m
  -%}
  
  <style>
    /* =========================================================
      1) FIX BACKDROP SCOPE (must live on BODY/ROOT, not popup)
    ========================================================= */
    body{
      --lag-atc-backdrop-d: {% if settings.lag_atc_backdrop_enable_d %}{{ bd_rgba_d }}{% else %}rgba(0,0,0,0){% endif %};
      --lag-atc-backdrop-m: {% if settings.lag_atc_backdrop_enable_m %}{{ bd_rgba_m }}{% else %}rgba(0,0,0,0){% endif %};
      --lag-atc-backdrop: var(--lag-atc-backdrop-d);
    }
    @media (max-width: 767px){
      body{ --lag-atc-backdrop: var(--lag-atc-backdrop-m); }
    }

    body.add-to-cart-show .background-overlay,
    body.add-to-cart-show .halo-background,
    body.add-to-cart-show .halo-overlay,
    body.add-to-cart-show .popup-overlay,
    body.add-to-cart-show .modal-overlay{
      background: var(--lag-atc-backdrop, rgba(0,0,0,0.18)) !important;
      opacity: 1 !important;
      z-index: 60 !important;
    }

    /* =========================================================
      2) Vars: bind to #halo-add-to-cart-popup (NOT inline style)
         So even if Halo rewrites classes, vars survive.
    ========================================================= */
    #halo-add-to-cart-popup{
      /* Desktop vars */
      --lag-popup-width-d: {{ settings.lag_atc_popup_width_d }}px;
      --lag-padding-d: {{ settings.lag_atc_popup_padding_d }}px;
      --lag-bg-d: {{ bg_rgba_d }};
      --lag-shadow-d: {% if settings.lag_atc_enable_shadow_d %}0 10px 30px rgba(0,0,0,0.18){% else %}none{% endif %};

      --lag-offset-x-d: {{ settings.lag_atc_offset_x_d }}px;
      --lag-offset-y-d: {{ settings.lag_atc_offset_y_d }}px;

      --lag-border-color-d: {{ settings.lag_atc_border_color_d }};
      --lag-border-width-d: {{ settings.lag_atc_border_width_d }}px;
      --lag-radius-d: {{ settings.lag_atc_border_radius_d }}px;

      --lag-title-color-d: {{ settings.lag_atc_title_color_d }};
      --lag-text-color-d: {{ settings.lag_atc_text_color_d }};
      --lag-title-size-d: {{ settings.lag_atc_title_size_d }}px;
      --lag-text-size-d: {{ settings.lag_atc_text_size_d }}px;
      --lag-title-weight-d: {{ settings.lag_atc_title_weight_d }};
      --lag-text-weight-d: {{ settings.lag_atc_text_weight_d }};

      --lag-image-size-d: {{ settings.lag_atc_image_size_d }}px;
      --lag-image-radius-d: {{ settings.lag_atc_image_radius_d }}px;

      --lag-btn-radius-d: {{ settings.lag_atc_button_radius_d }}px;
      --lag-btn-size-d: {{ settings.lag_atc_button_text_size_d }}px;

      --lag-btn-bg-d: {{ settings.lag_atc_view_cart_bg_d }};
      --lag-btn-fg-d: {{ settings.lag_atc_view_cart_fg_d }};
      --lag-btn-border-d: {{ settings.lag_atc_view_cart_border_d }};

      --lag-btn2-bg-d: {{ settings.lag_atc_continue_bg_d | default: 'transparent' }};
      --lag-btn2-fg-d: {{ settings.lag_atc_continue_fg_d }};
      --lag-btn2-border-d: {{ settings.lag_atc_continue_border_d }};

      --lag-progress-color-d: {{ settings.lag_atc_progress_color_d }};
      --lag-progress-overlay-d: {{ overlay_rgba_d }};

      --lag-close-size-d: {{ settings.lag_atc_close_size_d }}px;
      --lag-close-bg-d: {{ close_bg_rgba_d }};
      --lag-close-border-d: {{ settings.lag_atc_close_border_d }};
      --lag-close-icon-d: {{ settings.lag_atc_close_icon_color_d }};

      --lag-font-body-d: {% if settings.lag_atc_body_font_d != blank %}{{ settings.lag_atc_body_font_d.family }}, {{ settings.lag_atc_body_font_d.fallback_families }}{% else %}inherit{% endif %};
      --lag-font-title-d: {% if title_font_d != blank %}{{ title_font_d.family }}, {{ title_font_d.fallback_families }}{% else %}inherit{% endif %};
      --lag-font-text-d: {% if text_font_d != blank %}{{ text_font_d.family }}, {{ text_font_d.fallback_families }}{% else %}inherit{% endif %};
      --lag-font-btn-d: {% if btn_font_d != blank %}{{ btn_font_d.family }}, {{ btn_font_d.fallback_families }}{% else %}inherit{% endif %};

      --lag-strip-h-d: {{ settings.lag_atc_strip_height_d }}px;
      --lag-pad-x-d: {{ settings.lag_atc_padding_x_d }}px;
      --lag-pad-y-d: {{ settings.lag_atc_padding_y_d }}px;
      --lag-simple-outer-pad-d: {{ settings.lag_atc_simple_outer_padding_d }}px;

      /* Mobile vars */
      --lag-popup-width-m: {{ settings.lag_atc_popup_width_m }}px;
      --lag-padding-m: {{ settings.lag_atc_popup_padding_m }}px;
      --lag-bg-m: {{ bg_rgba_m }};
      --lag-shadow-m: {% if settings.lag_atc_enable_shadow_m %}0 10px 30px rgba(0,0,0,0.18){% else %}none{% endif %};

      --lag-offset-x-m: {{ settings.lag_atc_offset_x_m }}px;
      --lag-offset-y-m: {{ settings.lag_atc_offset_y_m }}px;

      --lag-border-color-m: {{ settings.lag_atc_border_color_m }};
      --lag-border-width-m: {{ settings.lag_atc_border_width_m }}px;
      --lag-radius-m: {{ settings.lag_atc_border_radius_m }}px;

      --lag-title-color-m: {{ settings.lag_atc_title_color_m }};
      --lag-text-color-m: {{ settings.lag_atc_text_color_m }};
      --lag-title-size-m: {{ settings.lag_atc_title_size_m }}px;
      --lag-text-size-m: {{ settings.lag_atc_text_size_m }}px;
      --lag-title-weight-m: {{ settings.lag_atc_title_weight_m }};
      --lag-text-weight-m: {{ settings.lag_atc_text_weight_m }};

      --lag-image-size-m: {{ settings.lag_atc_image_size_m }}px;
      --lag-image-radius-m: {{ settings.lag_atc_image_radius_m }}px;

      --lag-btn-radius-m: {{ settings.lag_atc_button_radius_m }}px;
      --lag-btn-size-m: {{ settings.lag_atc_button_text_size_m }}px;

      --lag-btn-bg-m: {{ settings.lag_atc_view_cart_bg_m }};
      --lag-btn-fg-m: {{ settings.lag_atc_view_cart_fg_m }};
      --lag-btn-border-m: {{ settings.lag_atc_view_cart_border_m }};

      --lag-btn2-bg-m: {{ settings.lag_atc_continue_bg_m | default: 'transparent' }};
      --lag-btn2-fg-m: {{ settings.lag_atc_continue_fg_m }};
      --lag-btn2-border-m: {{ settings.lag_atc_continue_border_m }};

      --lag-progress-color-m: {{ settings.lag_atc_progress_color_m }};
      --lag-progress-overlay-m: {{ overlay_rgba_m }};

      --lag-close-size-m: {{ settings.lag_atc_close_size_m }}px;
      --lag-close-bg-m: {{ close_bg_rgba_m }};
      --lag-close-border-m: {{ settings.lag_atc_close_border_m }};
      --lag-close-icon-m: {{ settings.lag_atc_close_icon_color_m }};

      --lag-font-body-m: {% if settings.lag_atc_body_font_m != blank %}{{ settings.lag_atc_body_font_m.family }}, {{ settings.lag_atc_body_font_m.fallback_families }}{% else %}inherit{% endif %};
      --lag-font-title-m: {% if title_font_m != blank %}{{ title_font_m.family }}, {{ title_font_m.fallback_families }}{% else %}inherit{% endif %};
      --lag-font-text-m: {% if text_font_m != blank %}{{ text_font_m.family }}, {{ text_font_m.fallback_families }}{% else %}inherit{% endif %};
      --lag-font-btn-m: {% if btn_font_m != blank %}{{ btn_font_m.family }}, {{ btn_font_m.fallback_families }}{% else %}inherit{% endif %};

      --lag-strip-h-m: {{ settings.lag_atc_strip_height_m }}px;
      --lag-pad-x-m: {{ settings.lag_atc_padding_x_m }}px;
      --lag-pad-y-m: {{ settings.lag_atc_padding_y_m }}px;
      --lag-simple-outer-pad-m: {{ settings.lag_atc_simple_outer_padding_m }}px;

      /* Active defaults = Desktop */
      --lag-popup-width: var(--lag-popup-width-d);
      --lag-padding: var(--lag-padding-d);
      --lag-bg: var(--lag-bg-d);
      --lag-shadow: var(--lag-shadow-d);

      --lag-offset-x: var(--lag-offset-x-d);
      --lag-offset-y: var(--lag-offset-y-d);

      --lag-border-color: var(--lag-border-color-d);
      --lag-border-width: var(--lag-border-width-d);
      --lag-radius: var(--lag-radius-d);

      --lag-title-color: var(--lag-title-color-d);
      --lag-text-color: var(--lag-text-color-d);
      --lag-title-size: var(--lag-title-size-d);
      --lag-text-size: var(--lag-text-size-d);
      --lag-title-weight: var(--lag-title-weight-d);
      --lag-text-weight: var(--lag-text-weight-d);

      --lag-image-size: var(--lag-image-size-d);
      --lag-image-radius: var(--lag-image-radius-d);

      --lag-btn-radius: var(--lag-btn-radius-d);
      --lag-btn-size: var(--lag-btn-size-d);

      --lag-btn-bg: var(--lag-btn-bg-d);
      --lag-btn-fg: var(--lag-btn-fg-d);
      --lag-btn-border: var(--lag-btn-border-d);

      --lag-btn2-bg: var(--lag-btn2-bg-d);
      --lag-btn2-fg: var(--lag-btn2-fg-d);
      --lag-btn2-border: var(--lag-btn2-border-d);

      --lag-progress-color: var(--lag-progress-color-d);
      --lag-progress-overlay: var(--lag-progress-overlay-d);

      --lag-close-size: var(--lag-close-size-d);
      --lag-close-bg: var(--lag-close-bg-d);
      --lag-close-border: var(--lag-close-border-d);
      --lag-close-icon: var(--lag-close-icon-d);

      --lag-font-body: var(--lag-font-body-d);
      --lag-font-title: var(--lag-font-title-d);
      --lag-font-text: var(--lag-font-text-d);
      --lag-font-btn: var(--lag-font-btn-d);

      --lag-strip-h: var(--lag-strip-h-d);
      --lag-pad-x: var(--lag-pad-x-d);
      --lag-pad-y: var(--lag-pad-y-d);
      --lag-simple-outer-pad: var(--lag-simple-outer-pad-d);
    }

    @media (max-width: 767px){
      #halo-add-to-cart-popup{
        --lag-popup-width: var(--lag-popup-width-m);
        --lag-padding: var(--lag-padding-m);
        --lag-bg: var(--lag-bg-m);
        --lag-shadow: var(--lag-shadow-m);

        --lag-offset-x: var(--lag-offset-x-m);
        --lag-offset-y: var(--lag-offset-y-m);

        --lag-border-color: var(--lag-border-color-m);
        --lag-border-width: var(--lag-border-width-m);
        --lag-radius: var(--lag-radius-m);

        --lag-title-color: var(--lag-title-color-m);
        --lag-text-color: var(--lag-text-color-m);
        --lag-title-size: var(--lag-title-size-m);
        --lag-text-size: var(--lag-text-size-m);
        --lag-title-weight: var(--lag-title-weight-m);
        --lag-text-weight: var(--lag-text-weight-m);

        --lag-image-size: var(--lag-image-size-m);
        --lag-image-radius: var(--lag-image-radius-m);

        --lag-btn-radius: var(--lag-btn-radius-m);
        --lag-btn-size: var(--lag-btn-size-m);

        --lag-btn-bg: var(--lag-btn-bg-m);
        --lag-btn-fg: var(--lag-btn-fg-m);
        --lag-btn-border: var(--lag-btn-border-m);

        --lag-btn2-bg: var(--lag-btn2-bg-m);
        --lag-btn2-fg: var(--lag-btn2-fg-m);
        --lag-btn2-border: var(--lag-btn2-border-m);

        --lag-progress-color: var(--lag-progress-color-m);
        --lag-progress-overlay: var(--lag-progress-overlay-m);

        --lag-close-size: var(--lag-close-size-m);
        --lag-close-bg: var(--lag-close-bg-m);
        --lag-close-border: var(--lag-close-border-m);
        --lag-close-icon: var(--lag-close-icon-m);

        --lag-font-body: var(--lag-font-body-m);
        --lag-font-title: var(--lag-font-title-m);
        --lag-font-text: var(--lag-font-text-m);
        --lag-font-btn: var(--lag-font-btn-m);

        --lag-strip-h: var(--lag-strip-h-m);
        --lag-pad-x: var(--lag-pad-x-m);
        --lag-pad-y: var(--lag-pad-y-m);
        --lag-simple-outer-pad: var(--lag-simple-outer-pad-m);
      }
    }

    /* =========================================================
      3) Core styling — target by ID + data attrs (NOT .lag-atc)
    ========================================================= */
    #halo-add-to-cart-popup,
    #halo-add-to-cart-popup *{
      box-sizing: border-box !important;
    }

    #halo-add-to-cart-popup{
      position: fixed !important;
      z-index: 80 !important;

      inset: auto !important;
      left: auto !important;
      right: auto !important;
      top: auto !important;
      bottom: auto !important;
      transform: none !important;

      border: var(--lag-border-width) solid var(--lag-border-color) !important;
      border-radius: var(--lag-radius) !important;
      background: var(--lag-bg) !important;
      box-shadow: var(--lag-shadow) !important;
      overflow: hidden !important;

      font-family: var(--lag-font-body) !important;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;

      --lag-safe-top: env(safe-area-inset-top, 0px);
      --lag-safe-right: env(safe-area-inset-right, 0px);
      --lag-safe-bottom: env(safe-area-inset-bottom, 0px);
      --lag-safe-left: env(safe-area-inset-left, 0px);

      --lag-close-reserve: calc(var(--lag-close-size, 36px) + 12px);
      --lag-simple-edge-left: max(calc(var(--lag-simple-outer-pad, 10px) + var(--lag-offset-x, 0px)), var(--lag-safe-left));
      --lag-simple-edge-right: max(calc(var(--lag-simple-outer-pad, 10px) + var(--lag-offset-x, 0px)), var(--lag-safe-right));
    }

    /* show/hide via canonical data attrs */
    #halo-add-to-cart-popup[data-lag-show-image="0"] .product-image{ display:none !important; }
    #halo-add-to-cart-popup[data-lag-show-title="0"] .product-title .title{ display:none !important; }
    #halo-add-to-cart-popup[data-lag-show-text="0"] .product-title .text{ display:none !important; }
    #halo-add-to-cart-popup[data-lag-show-buttons="0"] .product-action{ display:none !important; }
    #halo-add-to-cart-popup[data-lag-show-continue="0"] .button-continue{ display:none !important; }
    #halo-add-to-cart-popup[data-lag-show-viewcart="0"] .button-view-cart{ display:none !important; }
    #halo-add-to-cart-popup[data-lag-close-icon="0"] .halo-popup-close .lag-close-ico{
      display:none !important;
    }


    /* Position (data driven) */
    #halo-add-to-cart-popup[data-lag-position="top_right"]{
      top: calc(var(--lag-safe-top) + var(--lag-offset-y, 0px)) !important;
      right: calc(var(--lag-safe-right) + var(--lag-offset-x, 0px)) !important;
    }

    #halo-add-to-cart-popup[data-lag-position="bottom_center"]{
      left: 50% !important;
      bottom: calc(var(--lag-safe-bottom) + var(--lag-offset-y, 0px)) !important;
      transform: translateX(-50%) !important;
    }

    /* Width by mode */
    #halo-add-to-cart-popup[data-lag-mode="full"]{
      width: var(--lag-popup-width) !important;
      max-width: calc(100vw - 24px) !important;
    }
    #halo-add-to-cart-popup[data-lag-mode="simple"]{
      width: auto !important;
      max-width: calc(100vw - 24px) !important;
      min-width: 0 !important;
    }

    /* Simple fullwidth strip */
    #halo-add-to-cart-popup[data-lag-mode="simple"][data-lag-simple-fullwidth="1"]{
      left: var(--lag-simple-edge-left) !important;
      right: var(--lag-simple-edge-right) !important;
      width: auto !important;
      max-width: none !important;
      transform: none !important;
    }

    /* Autoclose BG fill overlay */
    #halo-add-to-cart-popup[data-lag-autoclose="1"][data-lag-ac-anim="bg_fill"]::after{
      content:"";
      position:absolute;
      inset:0;
      z-index:0;
      pointer-events:none;
      background: var(--lag-progress-overlay);
      transform: scaleX(var(--lag-ac-progress, 0));
      transform-origin: left center;
    }

    /* Content root */
    #halo-add-to-cart-popup .halo-popup-content{
      position: relative;
      z-index: 2;
      padding: var(--lag-padding, 14px) !important;
      padding-right: calc(var(--lag-padding, 14px) + var(--lag-close-reserve)) !important;
    }

    /* Layout reset */
    #halo-add-to-cart-popup .product-added{
      display:flex !important;
      align-items:center !important;
      gap: 12px !important;
      width: 100% !important;
      font-size: inherit !important;
      margin: 0 !important;
      padding: 0 !important;
    }
    #halo-add-to-cart-popup .product-added::before,
    #halo-add-to-cart-popup .product-added::after{
      content:none !important;
      display:none !important;
    }

    /* Image (force display; some Halo variants hide it) */
    #halo-add-to-cart-popup .product-image{
      display:block !important;
      width: var(--lag-image-size) !important;
      height: var(--lag-image-size) !important;
      border-radius: var(--lag-image-radius) !important;
      overflow:hidden !important;
      flex: 0 0 auto !important;
      background-size: cover !important;
      background-position: center !important;
    }
    #halo-add-to-cart-popup .product-image img{
      width:100% !important;
      height:100% !important;
      object-fit:cover !important;
      display:block !important;
    }
    #halo-add-to-cart-popup .product-image img:not([src]),
    #halo-add-to-cart-popup .product-image img[src=""]{
      display:none !important;
    }

    /* Info column */
    #halo-add-to-cart-popup .product-info{
      flex: 1 1 auto !important;
      min-width: 0 !important;
      display:flex !important;
      flex-direction: column !important;
      gap: 8px !important;
      width: auto !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    /* Typography */
    #halo-add-to-cart-popup .product-title{
      margin:0 !important;
      padding:0 !important;
