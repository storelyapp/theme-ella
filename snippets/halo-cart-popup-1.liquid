      left: 0 !important;
      right: 0 !important;
      width: 100vw !important;
      max-width: 100vw !important;
    }
  </style>

  <div
    class="halo-popup halo-add-to-cart-popup customPopup-tiny"
    data-add-to-cart-popup
    id="halo-add-to-cart-popup"

    data-lag-atc="1"
    data-lag-mode="{{ settings.lag_atc_mode_d }}"
