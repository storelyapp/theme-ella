    <a class="lag-atc-action halo-popup-cart" href="{{ routes.cart_url }}" aria-label="{{ 'sections.cart.view_cart' | t }}">
      <svg class="lag-ac-ring" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
        <circle class="lag-ac-ring-track" cx="50" cy="50" r="45"></circle>
        <circle class="lag-ac-ring-prog"  cx="50" cy="50" r="45"></circle>
      </svg>

      <span class="lag-cart-ico" aria-hidden="true">
        <svg viewBox="0 0 32 32" class="icon icon-cart" aria-hidden="true" focusable="false" role="presentation">
          <path
            d="M 16 3 C 13.253906 3 11 5.253906 11 8 L 11 9 L 6.0625 9 L 6 9.9375 L 5 27.9375 L 4.9375 29 L 27.0625 29 L 27 27.9375 L 26 9.9375 L 25.9375 9 L 21 9 L 21 8 C 21 5.253906 18.746094 3 16 3 Z M 16 5 C 17.65625 5 19 6.34375 19 8 L 19 9 L 13 9 L 13 8 C 13 6.34375 14.34375 5 16 5 Z M 7.9375 11 L 11 11 L 11 14 L 13 14 L 13 11 L 19 11 L 19 14 L 21 14 L 21 11 L 24.0625 11 L 24.9375 27 L 7.0625 27 Z"
            fill="#FFFFFF"
            stroke="currentColor"
            stroke-width="0"
            stroke-linejoin="round"
            stroke-linecap="round"
          />
        </svg>
      </span>
    </a>


    <div class="halo-popup-content">
      <div class="product-added">
        <a class="product-image" href="">
          <img alt="" loading="lazy" decoding="async">
        </a>

        <div class="product-info">
          <div class="product-title">
            <a class="title" href=""></a>
            <span class="text">{{ success_msg_d }}</span>
          </div>

          <div class="product-action">
            <a class="button button-2 button-continue"
              {% if settings.quick_cart_redirect_button == 'go_back' %}
                role="link" aria-disabled="true" onclick="window.history.back();"
              {% elsif settings.quick_cart_redirect_button == 'link_to' %}
                href="{{ settings.quick_cart_redirect_button_link }}"
              {% else %}
                role="link" aria-disabled="true" onclick="window.location.reload();"
              {% endif %}
            >{{ continue_label_d }}</a>

            <a class="button button-2 button-view-cart" href="{{ routes.cart_url }}">
              {{ view_cart_label_d }}
            </a>
