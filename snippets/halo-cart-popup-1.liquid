        display:block !important;
      }
      #halo-add-to-cart-popup[data-lag-mode="full"] .product-title .text{
        opacity: 0.95 !important;
        margin-top: 4px !important;
      }
      #halo-add-to-cart-popup[data-lag-mode="full"] .halo-popup-content{
        padding: 12px !important;
        padding-right: calc(12px + var(--lag-close-reserve)) !important;
      }

      #halo-add-to-cart-popup .product-action .button{
        flex: 1 1 140px !important;
        min-width: 140px !important;
        padding: 11px 12px !important;
      }

      #halo-add-to-cart-popup[data-lag-mode="simple"] .halo-popup-content{
        height: clamp(44px, var(--lag-strip-h), 88px) !important;
      }

      #halo-add-to-cart-popup .product-title .title{
        font-size: clamp(12px, var(--lag-title-size), 16px) !important;
      }
      #halo-add-to-cart-popup .product-title .text{
        font-size: clamp(12px, var(--lag-text-size), 14px) !important;
      }
    }

    /* Ensure popup above overlay */
    #halo-add-to-cart-popup{ z-index: 80 !important; }

    /* =========================
      MOBILE SIMPLE = STRIP
    ========================= */
    @media (max-width: 767px){
      /* Force strip geometry even if attrs glitch for a frame */
      #halo-add-to-cart-popup[data-lag-mode="simple"]{
        left: var(--lag-simple-edge-left) !important;
        right: var(--lag-simple-edge-right) !important;
        bottom: calc(var(--lag-safe-bottom) + var(--lag-offset-y, 0px)) !important;
        width: auto !important;
        max-width: none !important;
        transform: none !important;
      }

      /* Strip padding: reserve ONLY on the right for the action button */
      #halo-add-to-cart-popup[data-lag-mode="simple"] .halo-popup-content{
        justify-content: flex-start !important;
        padding-left: var(--lag-pad-x, 18px) !important;
        padding-right: calc(var(--lag-pad-x, 18px) + var(--lag-close-reserve)) !important;
      }

      #halo-add-to-cart-popup[data-lag-mode="simple"] .product-added{
        justify-content: flex-start !important;
      }

      #halo-add-to-cart-popup[data-lag-mode="simple"] .product-info{
