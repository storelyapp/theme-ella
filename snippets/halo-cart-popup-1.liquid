        autoclose_enable: {{ settings.lag_atc_autoclose_enable_m | json }},
        autoclose_seconds: {{ settings.lag_atc_autoclose_seconds_m | json }},
        pause_on_hover: {{ settings.lag_atc_pause_on_hover_m | json }},
        ac_anim: {{ settings.lag_atc_autoclose_animation_m | json }},
        show_close_icon: {{ settings.lag_atc_show_close_icon_m | json }},
        simple_fullwidth: {{ settings.lag_atc_simple_fullwidth_m | json }},

        show_image: {{ settings.lag_atc_show_image_m | json }},
        show_title: {{ settings.lag_atc_show_title_m | json }},
        show_text: {{ settings.lag_atc_show_text_m | json }},
        show_buttons: {{ settings.lag_atc_show_buttons_m | json }},
        show_continue: {{ settings.lag_atc_show_continue_button_m | json }},
        show_viewcart: {{ settings.lag_atc_show_view_cart_button_m | json }},

        success_text: {{ success_msg_m | json }},
        continue_label: {{ continue_label_m | json }},
        viewcart_label: {{ view_cart_label_m | json }},
        action: {{ settings.lag_atc_mobile_action_m | default: 'close' | json }}
      }
    };

    function $(sel, root){ return (root || document).querySelector(sel); }
    function getPopup(){ return document.getElementById("halo-add-to-cart-popup"); }
    function isOpen(){ return document.body.classList.contains("add-to-cart-show"); }

    function to01(v){ return v ? "1" : "0"; }

    function ensureRing(btn){
      if (!btn) return;
      if ($('.lag-ac-ring', btn)) return;

      var svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
      svg.setAttribute("class", "lag-ac-ring");
      svg.setAttribute("viewBox", "0 0 100 100");
      svg.setAttribute("aria-hidden", "true");
      svg.setAttribute("focusable", "false");

      var c1 = document.createElementNS("http://www.w3.org/2000/svg", "circle");
      c1.setAttribute("class", "lag-ac-ring-track");
      c1.setAttribute("cx", "50"); c1.setAttribute("cy", "50"); c1.setAttribute("r", "45");

      var c2 = document.createElementNS("http://www.w3.org/2000/svg", "circle");
      c2.setAttribute("class", "lag-ac-ring-prog");
      c2.setAttribute("cx", "50"); c2.setAttribute("cy", "50"); c2.setAttribute("r", "45");

      svg.appendChild(c1);
      svg.appendChild(c2);

      btn.insertBefore(svg, btn.firstChild);
    }

    function stamp(popup){
      if (!popup) return null;
      popup.setAttribute("data-lag-atc", "1");

      var closeBtn = $('[data-close-add-to-cart-popup]', popup);
      ensureRing(closeBtn);

      var cartBtn = $('.halo-popup-cart', popup);
      ensureRing(cartBtn);

      var imgA = $(".product-image", popup);
      if (imgA && !$("img", imgA)) {
        var img = document.createElement("img");
        img.alt = "";
        img.loading = "lazy";
        img.decoding = "async";
        imgA.appendChild(img);
      }
      return popup;
    }

    function init(popup){
      if (!popup || popup.dataset.lagInit === "1") return;
      popup.dataset.lagInit = "1";

      var closeBtn = $('[data-close-add-to-cart-popup]', popup);
      var successEl = $('.product-title .text', popup);
      var continueEl = $('.button-continue', popup);
      var viewCartEl = $('.button-view-cart', popup);

      var mq = window.matchMedia("(max-width: 767px)");
      var activeProfile = null;

      var rafId = 0;
      var running = false;
      var t0 = 0;
      var pausedAt = 0;
      var pausedTotal = 0;

      function readConfig(){
        return {
          enable: popup.getAttribute("data-lag-autoclose") === "1",
          seconds: Math.max(0, parseInt(popup.getAttribute("data-lag-ac-seconds") || "0", 10) || 0),
          pauseOnHover: popup.getAttribute("data-lag-ac-pause") === "1"
        };
      }

      function stop(){
        running = false;
        if (rafId) cancelAnimationFrame(rafId);
        rafId = 0;
        popup.style.removeProperty("--lag-ac-progress");
        popup.style.removeProperty("--lag-ac-deg");
        popup.style.removeProperty("--lag-ac-dash");
      }

      function forceCloseFallback(){
        document.body.classList.remove("add-to-cart-show");
        popup.style.display = "none";
        popup.setAttribute("aria-hidden", "true");
      }

      function isModifiedClick(e){
        return e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0;
      }

      function closePopupFast(){
        stop();
        try { if (closeBtn) closeBtn.click(); } catch(_) {}
        setTimeout(function(){ if (isOpen()) forceCloseFallback(); }, 80);
      }

      function finishClose(){
        stop();
        try { if (closeBtn) closeBtn.click(); } catch(e) {}
        setTimeout(function(){ if (isOpen()) forceCloseFallback(); }, 140);
      }

      function tick(now){
        if (!running) return;

        var cfg = readConfig();
        var dur = Math.max(1, cfg.seconds) * 1000;

        var elapsed = now - t0 - pausedTotal;
        var p = Math.max(0, Math.min(1, elapsed / dur));

        popup.style.setProperty("--lag-ac-progress", String(p));
        popup.style.setProperty("--lag-ac-deg", (p * 360).toFixed(2) + "deg");

        // r=45 => C ≈ 282.743 ; dashoffset = (1 - p) * C
        var C = 282.743;
        popup.style.setProperty("--lag-ac-dash", ((1 - p) * C).toFixed(3)); // <-- add this

        if (elapsed >= dur) { finishClose(); return; }
        rafId = requestAnimationFrame(tick);
      }


      function start(){
        stop();
        var cfg = readConfig();
        if (!cfg.enable || cfg.seconds < 1) return;

        popup.style.removeProperty("display");
        popup.removeAttribute("aria-hidden");

        running = true;
        t0 = performance.now();
        pausedAt = 0;
        pausedTotal = 0;

        popup.style.setProperty("--lag-ac-progress", "0");
        popup.style.setProperty("--lag-ac-deg", "0deg");
        popup.style.setProperty("--lag-ac-dash", "282.743");

        rafId = requestAnimationFrame(tick);
      }

      function pause(){
        if (!running || pausedAt) return;
        pausedAt = performance.now();
      }

      function resume(){
        if (!running || !pausedAt) return;
        pausedTotal += (performance.now() - pausedAt);
        pausedAt = 0;
      }

      function profileKey(){ return mq.matches ? "m" : "d"; }

      function applyProfile(p){
        if (activeProfile === p) return;
        activeProfile = p;

        var c = CFG[p] || CFG.d;
        var isMobile = (p === "m");

        var mode = (c.mode === "simple" ? "simple" : "full");
        var wantsStrip = isMobile && mode === "simple";

        // Mode / Position
        popup.setAttribute("data-lag-mode", mode);
        popup.setAttribute("data-lag-position", wantsStrip ? "bottom_center"
          : (c.position === "bottom_center" ? "bottom_center" : "top_right"));

        // Force fullwidth strip on mobile simple
        popup.setAttribute("data-lag-simple-fullwidth", wantsStrip ? "1" : to01(!!c.simple_fullwidth));

        // ✅ Cart ONLY for mobile simple; otherwise close
        popup.setAttribute("data-lag-action", wantsStrip ? "cart" : "close");

        // ✅ In strip: force minimal content regardless of settings
        var showImage    = wantsStrip ? false : !!c.show_image;
        var showTitle    = wantsStrip ? false : !!c.show_title;
        var showText     = wantsStrip ? true  : !!c.show_text;
        var showButtons  = wantsStrip ? false : !!c.show_buttons;
        var showContinue = wantsStrip ? false : !!c.show_continue;
        var showViewCart = wantsStrip ? false : !!c.show_viewcart;

        popup.setAttribute("data-lag-show-image", to01(showImage));
        popup.setAttribute("data-lag-show-title", to01(showTitle));
        popup.setAttribute("data-lag-show-text", to01(showText));
        popup.setAttribute("data-lag-show-buttons", to01(showButtons));
        popup.setAttribute("data-lag-show-continue", to01(showContinue));
        popup.setAttribute("data-lag-show-viewcart", to01(showViewCart));

        // Close icon visibility (keep your setting)
        popup.setAttribute("data-lag-close-icon", to01(!!c.show_close_icon));

        // ✅ Autoclose: keep user setting, but for strip we force-enable so it never “sticks”
        var acEnable = wantsStrip ? true : !!c.autoclose_enable;
        var acSeconds = parseInt(c.autoclose_seconds || 0, 10) || 0;
        if (wantsStrip && acSeconds < 1) acSeconds = 5;

        popup.setAttribute("data-lag-autoclose", to01(acEnable));
        popup.setAttribute("data-lag-ac-seconds", String(acSeconds));
        popup.setAttribute("data-lag-ac-pause", to01(!!c.pause_on_hover));
        popup.setAttribute("data-lag-ac-anim", (c.ac_anim === "bg_fill" ? "bg_fill" : "close_ring"));

        // Text swap
        if (successEl && typeof c.success_text === "string") successEl.textContent = c.success_text;
        if (continueEl && typeof c.continue_label === "string") continueEl.textContent = c.continue_label;
        if (viewCartEl && typeof c.viewcart_label === "string") viewCartEl.textContent = c.viewcart_label;

        // Ring host: in strip use cart, otherwise close
        var cartBtn = $(".halo-popup-cart", popup);
        if (closeBtn) closeBtn.classList.remove("is-ring-host");
        if (cartBtn) cartBtn.classList.remove("is-ring-host");
        if (wantsStrip) { if (cartBtn) cartBtn.classList.add("is-ring-host"); }
        else { if (closeBtn) closeBtn.classList.add("is-ring-host"); }

        stop();
        if (isOpen()) start();
      }

      // Pause on hover/focus if enabled
      popup.addEventListener("mouseenter", function(){ if (readConfig().pauseOnHover) pause(); }, { passive:true });
      popup.addEventListener("mouseleave", function(){ if (readConfig().pauseOnHover) resume(); }, { passive:true });
      popup.addEventListener("focusin",    function(){ if (readConfig().pauseOnHover) pause(); }, { passive:true });
      popup.addEventListener("focusout",   function(){ if (readConfig().pauseOnHover) resume(); }, { passive:true });

      if (closeBtn) closeBtn.addEventListener("click", stop, { passive:true });

      // Initial apply
      applyProfile(profileKey());

      // Breakpoint change
      if (mq.addEventListener) mq.addEventListener("change", function(){ applyProfile(profileKey()); });
      else if (mq.addListener) mq.addListener(function(){ applyProfile(profileKey()); });

      // Halo open/close tracking (also re-stamp after open; Halo may rewrite markup)
      var lastOpen = isOpen();
      if (lastOpen) start();

      var bodyObserver = new MutationObserver(function(){
        var nowOpen = isOpen();

        // Always enforce correct profile; also re-stamp just after open
        applyProfile(profileKey());
        if (nowOpen && !lastOpen) {
          setTimeout(function(){
            stamp(popup);
            applyProfile(profileKey());
            start();
          }, 0);
        }
        if (!nowOpen && lastOpen) stop();

        lastOpen = nowOpen;
      });

      bodyObserver.observe(document.body, { attributes:true, attributeFilter:["class"] });

      document.addEventListener("visibilitychange", function(){
        if (document.hidden) pause();
        else resume();
      });
    }

    // Boot robustly (in case Halo injects/replaces popup later)
    function boot(){
      var p = stamp(getPopup());
      if (p) init(p);
    }

    boot();
    document.addEventListener("DOMContentLoaded", boot);

    // A few retries for themes that inject late
    var tries = 0;
    var t = setInterval(function(){
      tries++;
      boot();
      if (getPopup() && getPopup().dataset.lagInit === "1") clearInterval(t);
      if (tries > 30) clearInterval(t);
    }, 250);

  })();
  </script>
{%- endif -%}