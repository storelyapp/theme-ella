    #halo-add-to-cart-popup[data-lag-mode="simple"] .product-image,
    #halo-add-to-cart-popup[data-lag-mode="simple"] .product-action,
    #halo-add-to-cart-popup[data-lag-mode="simple"] .product-title .title{
      display:none !important;
    }

    #halo-add-to-cart-popup[data-lag-mode="simple"] .halo-popup-content{
      display:flex !important;
      align-items:center !important;
      justify-content:center !important;
      height: var(--lag-strip-h) !important;

      --lag-pad-y-cap: min(
        var(--lag-pad-y, 10px),
        max(0px, calc((var(--lag-strip-h) - 1.2em) / 2))
      );

      padding-top: var(--lag-pad-y-cap) !important;
      padding-bottom: var(--lag-pad-y-cap) !important;
      padding-left: calc(var(--lag-pad-x, 18px) + var(--lag-close-reserve)) !important;
