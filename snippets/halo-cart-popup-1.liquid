    data-lag-show-continue="{% if settings.lag_atc_show_continue_button_d %}1{% else %}0{% endif %}"
    data-lag-show-viewcart="{% if settings.lag_atc_show_view_cart_button_d %}1{% else %}0{% endif %}"
    data-lag-cart-url="{{ routes.cart_url }}"
    data-lag-cart-aria="{{ 'sections.cart.view_cart' | t | escape }}"
    data-lag-action="close"  
  >
    <button type="button" class="lag-atc-action halo-popup-close is-ring-host" data-close-add-to-cart-popup aria-label="{{ 'general.common.close' | t }}">
      <svg class="lag-ac-ring" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
