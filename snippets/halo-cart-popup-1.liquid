      --lag-action-gap: 10px;

      /* Ring tuning (outside button with gap) */
      --lag-ring-gap: 4px; /* space between button edge and ring */
      --lag-ring-w: clamp(2px, calc(var(--lag-close-size) * 0.09), 3.5px);

      /* Total ring box size = button + (gap + stroke) on both sides */
      --lag-ring-size: calc(var(--lag-close-size) + (2 * (var(--lag-ring-gap) + var(--lag-ring-w))));
    }

    /* Default: show close; hide cart */
    #halo-add-to-cart-popup .halo-popup-cart{ display:none !important; }

    /* Switch action by profile */
    #halo-add-to-cart-popup[data-lag-action="cart"] .halo-popup-close{ display:none !important; }
    #halo-add-to-cart-popup[data-lag-action="cart"] .halo-popup-cart{ display:inline-flex !important; }

    #halo-add-to-cart-popup[data-lag-action="both"] .halo-popup-cart{ display:inline-flex !important; }
    #halo-add-to-cart-popup[data-lag-action="both"] .halo-popup-cart{
      right: calc(var(--lag-action-inset) + var(--lag-close-size) + var(--lag-action-gap)) !important;
    }

    /* Shared action button base */
    #halo-add-to-cart-popup .lag-atc-action{
      position:absolute !important;
      z-index: 3 !important;
      top: 50% !important;
      transform: translateY(-50%) !important;
      right: var(--lag-action-inset) !important;

      width: var(--lag-close-size) !important;
      height: var(--lag-close-size) !important;

      border-radius: 999px !important;
      background: var(--lag-close-bg) !important;
      border: 1px solid var(--lag-close-border) !important;

      display:inline-flex !important;
      align-items:center !important;
      justify-content:center !important;

      padding:0 !important;
      margin:0 !important;
      cursor:pointer !important;
      text-decoration:none !important;

      /* IMPORTANT: prevents ring from creating horizontal overflow */
      overflow: hidden !important;

      /* icons use currentColor */
      color: var(--lag-close-icon) !important;
      -webkit-tap-highlight-color: transparent;
    }

    /* Icon sizing */
    #halo-add-to-cart-popup .lag-atc-action .lag-close-ico svg,
    #halo-add-to-cart-popup .lag-atc-action .lag-cart-ico svg{
      width: calc(var(--lag-close-size) - 16px) !important;
      height: calc(var(--lag-close-size) - 16px) !important;
      display:block !important;
    }

    /* Force close SVG strokes to theme color */
    #halo-add-to-cart-popup .lag-atc-action .lag-close-ico svg *{
      stroke: var(--lag-close-icon) !important;
    }

    /* Hide X icon if configured (button still clickable) */
    #halo-add-to-cart-popup[data-lag-close-icon="0"] .halo-popup-close .lag-close-ico{
      display:none !important;
