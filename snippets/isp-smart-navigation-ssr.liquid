  window.FS_INITIALIZE_CSS_MEDIA = () => {if(!fsGetUserVariation()) {
    ['fast-serp-css', 'fast-serp-custom-css'].forEach(id => {
      document.getElementById(id).media = '';
    });
  }}
  if(!window.FS_WAIT_FOR_POST_LOAD) {
    window.FS_INITIALIZE_CSS_MEDIA();
  }
