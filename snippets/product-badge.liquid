{%- liquid
  assign position = settings.badge_postion

  assign sale_badge = false
  assign sold_out_badge = false
  assign custom_badge = false
  assign bundle_badge = false
  assign new_badge = false

  assign sale_badge_type = settings.sale_badge_type
  assign new_badge_type = settings.new_badge_type
  assign custom_badge_text = product.metafields.custom.custom_badge

  if settings.show_sale_badge
    if badge_detail
      assign current_variant = product.selected_or_first_available_variant
      if current_variant.compare_at_price > current_variant.price
        assign sale_badge = true
      endif
    else
      if product.compare_at_price_min > product.price_min
        assign sale_badge = true
      endif
    endif
  endif

  if settings.show_sold_out_badge and product.available == false
    assign sold_out_badge = true
  endif

  if settings.show_custom_badge
    for tag in product.tags
      assign tag_handle = tag | handle
      if tag_handle == 'label'
        assign custom_badge = true
      endif
    endfor

    if custom_badge_text != blank
      assign custom_badge = true
    endif
  endif

  if settings.show_bundle_badge and product.metafields.c_f.grouped_sub_product
    assign bundle_badge = true
  endif

  if settings.show_new_badge
    if new_badge_type == 'auto'
      assign date_published = product.published_at | date: '%s'
      assign date_now = 'now' | date: '%s'
      assign date_minus = date_now | minus: date_published
      assign date_difference = date_minus | divided_by: 86400
      assign new_badge_limit = settings.new_badge_limit
      assign new_badge_time = settings.new_badge_time

      if date_difference < new_badge_time
        if serial <= new_badge_limit
          assign new_badge = true
        endif
      endif
    else
      for tag in product.tags
        assign tag_handle = tag | handle
        if tag_handle == 'new' or tag_handle == 'just-arrived' or tag_handle == 'just_arrived'
          assign new_badge = true
        endif
      endfor
    endif
  endif
-%}

{%- if sale_badge or sold_out_badge or custom_badge or bundle_badge or new_badge -%}
  <div
    class="{{ class }} halo-productBadges halo-productBadges--modern badge-{{ position }} halo-productBadges--{{ position }}{% if sale_badge_type == 'discount' or sale_badge_type == 'text_discount' %} has-badge-js{% endif %}{% unless sale_badge %} sale_badge_disable{% endunless %}"
    {% if sale_badge_type == 'text_discount' or sale_badge_type == 'text' %}
      data-text-sale-badge="{{ 'products.product.on_sale' | t }}"
    {% endif %}
    {% if sale_badge_type == 'discount' %}
      data-text-sale-badge="- "
    {% endif %}
    data-new-badge-number="{{ settings.new_badge_limit }}"
  >
    {%- if new_badge -%}
      <span class="badge badge--light badge--new just-arrived-badge" aria-hidden="true">
        Just Arrived
      </span>
    {%- endif -%}

    {%- if sale_badge -%}
      <span class="badge badge--light badge--sale sale-badge" aria-hidden="true">
        {%- if sale_badge_type == 'discount' -%}
          {%- if badge_detail -%}
            Save {{ current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round }}%
          {%- else -%}
            {% liquid
              assign list_compare = product.variants | where: 'compare_at_price'
              assign compare = 0
              for variant in list_compare
                assign saving = variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round
                if saving > compare
                  assign compare = saving
                endif
              endfor
              if compare < 1
                assign compare = product.compare_at_price_min | minus: product.price_min | times: 100.0 | divided_by: product.compare_at_price_min | round
              endif
            %}
            Save {{ compare }}%
          {%- endif -%}

        {%- elsif sale_badge_type == 'text_discount' -%}
          {{ 'products.product.on_sale' | t }}
          {%- if badge_detail -%}
            {{ current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round }}%
          {%- else -%}
            {% liquid
              assign list_compare = product.variants | where: 'compare_at_price'
              assign compare = 0
              for variant in list_compare
                assign saving = variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round
                if saving > compare
                  assign compare = saving
                endif
              endfor
              if compare < 1
                assign compare = product.compare_at_price_min | minus: product.price_min | times: 100.0 | divided_by: product.compare_at_price_min | round
              endif
            %}
            {{ compare }}%
          {%- endif -%}

        {%- else -%}
          {{ 'products.product.on_sale' | t }}
        {%- endif -%}
      </span>
    {%- endif -%}

    {%- if sold_out_badge -%}
      <span class="badge badge--light badge--sold-out sold-out-badge" aria-hidden="true">
        Out of Stock
      </span>
    {%- endif -%}

    {%- if custom_badge -%}
      <span class="badge badge--light badge--custom custom-badge" aria-hidden="true">
        {%- if custom_badge_text != blank -%}
          {{ custom_badge_text }}
        {%- else -%}
          {{ 'products.product.custom' | t }}
        {%- endif -%}
      </span>
    {%- endif -%}

    {%- if bundle_badge -%}
      <span class="badge badge--light badge--bundle bundle-badge" aria-hidden="true">
        {{ 'products.product.bundle' | t }}
      </span>
    {%- endif -%}
  </div>
{%- endif -%}