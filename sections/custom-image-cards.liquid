{% liquid
  assign section_id = 'image-cards-' | append: section.id
  assign layout_mode = section.settings.layout_mode
%}

<section id="{{ section_id }}" class="custom-image-cards-section layout-{{ layout_mode }}">
  <div class="custom-image-cards-wrapper page-width{% if section.settings.full_width %} full-width{% endif %}">
    
    {% if section.settings.heading != blank or section.settings.description != blank %}
      <div class="custom-image-cards-header">
        {% if section.settings.heading != blank %}
          <h2 class="custom-image-cards-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="custom-image-cards-description rte">{{ section.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="custom-image-cards-list {% if layout_mode == 'slider' %}is-slider{% else %}is-grid{% endif %}" data-layout="{{ layout_mode }}">
      {% for block in section.blocks %}
        <div class="custom-image-card" {{ block.shopify_attributes }}>
          {% if block.settings.card_link != blank %}
            <a href="{{ block.settings.card_link }}" class="custom-image-card-link">
          {% endif %}

          <div class="custom-image-card-inner">
            {% if block.settings.image != blank %}
              <div class="custom-image-card-media">
                {{
                  block.settings.image
                  | image_url: width: 2000
                  | image_tag:
                    loading: 'lazy',
                    widths: '375, 550, 750, 900, 1100, 1500, 2000',
                    class: 'custom-image-card-image',
                    alt: block.settings.image.alt | escape
                }}
              </div>
            {% else %}
              <div class="custom-image-card-media custom-image-card-placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}

            {% if block.settings.card_title != blank or block.settings.card_text != blank or block.settings.button_label != blank %}
              <div class="custom-image-card-content">
                {% if block.settings.card_title != blank %}
                  <h3 class="custom-image-card-title">{{ block.settings.card_title }}</h3>
                {% endif %}

                {% if block.settings.card_text != blank %}
                  <div class="custom-image-card-text rte">{{ block.settings.card_text }}</div>
                {% endif %}

                {% if block.settings.button_label != blank and block.settings.card_link != blank %}
                  <span class="custom-image-card-button">{{ block.settings.button_label }}</span>
                {% endif %}
              </div>
            {% endif %}
          </div>

          {% if block.settings.card_link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  <style>
    #{{ section_id }} {
      --section-pt: {{ section.settings.padding_top }}px;
      --section-pb: {{ section.settings.padding_bottom }}px;
      --section-pl: {{ section.settings.padding_left }}px;
      --section-pr: {{ section.settings.padding_right }}px;

      --heading-size: {{ section.settings.heading_size }}px;
      --desc-size: {{ section.settings.description_size }}px;
      --card-title-size: {{ section.settings.card_title_size }}px;
      --card-text-size: {{ section.settings.card_text_size }}px;

      --section-bg: {{ section.settings.section_bg }};
      --heading-color: {{ section.settings.heading_color }};
      --description-color: {{ section.settings.description_color }};
      --card-bg: {{ section.settings.card_bg }};
      --text-color: {{ section.settings.text_color }};
      --button-bg: {{ section.settings.button_bg }};
      --button-color: {{ section.settings.button_color }};
      --card-radius: {{ section.settings.card_radius }}px;
      --card-gap: {{ section.settings.card_gap }}px;

      --card-padding-top: {{ section.settings.card_padding_top }}px;
      --card-padding-right: {{ section.settings.card_padding_right }}px;
      --card-padding-bottom: {{ section.settings.card_padding_bottom }}px;
      --card-padding-left: {{ section.settings.card_padding_left }}px;

      --image-radius: {{ section.settings.image_radius }}px;
      --border-width: {{ section.settings.card_border_width }}px;
      --border-color: {{ section.settings.card_border_color }};
      --shadow-opacity: {{ section.settings.card_shadow_opacity | divided_by: 100.0 }};
      --cards-per-row: {{ section.settings.cards_per_row_desktop }};
      --cards-per-row-mobile: {{ section.settings.cards_per_row_mobile }};
    }

    #{{ section_id }} {
      background: var(--section-bg);
      padding-top: var(--section-pt);
      padding-bottom: var(--section-pb);
      padding-left: var(--section-pl);
      padding-right: var(--section-pr);
    }

    #{{ section_id }} .custom-image-cards-wrapper.full-width {
      max-width: 100%;
      padding-left: 0;
      padding-right: 0;
    }

    #{{ section_id }} .custom-image-cards-header {
      text-align: {{ section.settings.text_alignment }};
      margin-bottom: 28px;
    }

    #{{ section_id }} .custom-image-cards-heading {
      margin: 0 0 10px;
      font-size: var(--heading-size);
      line-height: 1.2;
      color: var(--heading-color);
      font-family: {{ section.settings.heading_font_family }};
      font-weight: {{ section.settings.heading_font_weight }};
    }

    #{{ section_id }} .custom-image-cards-description {
      margin: 0;
      font-size: var(--desc-size);
      line-height: 1.6;
      color: var(--description-color);
      font-family: {{ section.settings.description_font_family }};
      font-weight: {{ section.settings.description_font_weight }};
      opacity: 0.9;
    }

    #{{ section_id }} .custom-image-cards-list.is-grid {
      display: grid;
      grid-template-columns: repeat(var(--cards-per-row), minmax(0, 1fr));
      gap: var(--card-gap);
    }

    #{{ section_id }} .custom-image-cards-list.is-slider {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: calc((100% - (var(--card-gap) * ({{ section.settings.slider_visible_desktop }} - 1))) / {{ section.settings.slider_visible_desktop }});
      gap: var(--card-gap);
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 4px;
    }

    #{{ section_id }} .custom-image-cards-list.is-slider::-webkit-scrollbar {
      display: none;
    }

    #{{ section_id }} .custom-image-card {
      min-width: 0;
    }

    #{{ section_id }} .custom-image-cards-list.is-slider .custom-image-card {
      scroll-snap-align: start;
    }

    #{{ section_id }} .custom-image-card-link {
      display: block;
      text-decoration: none;
      color: inherit;
      height: 100%;
    }

    #{{ section_id }} .custom-image-card-inner {
      background: var(--card-bg);
      border-radius: var(--card-radius);
      overflow: hidden;
      height: 100%;
      border: var(--border-width) solid var(--border-color);
      box-shadow: 0 8px 24px rgba(0, 0, 0, var(--shadow-opacity));
    }

    #{{ section_id }} .custom-image-card-media {
      width: 100%;
      overflow: hidden;
      border-radius: var(--image-radius);
      background: transparent;
      line-height: 0;
    }

    #{{ section_id }} .custom-image-card-image {
      width: 100%;
      height: auto !important;
      display: block;
      object-fit: contain;
      object-position: center;
    }

    #{{ section_id }} .custom-image-card-placeholder svg,
    #{{ section_id }} .custom-image-card-placeholder .placeholder-svg {
      width: 100%;
      height: auto;
      display: block;
      background: #f3f3f3;
    }

    #{{ section_id }} .custom-image-card-content {
      padding-top: var(--card-padding-top);
      padding-right: var(--card-padding-right);
      padding-bottom: var(--card-padding-bottom);
      padding-left: var(--card-padding-left);
    }

    #{{ section_id }} .custom-image-card-title {
      margin: 0 0 10px;
      font-size: var(--card-title-size);
      line-height: 1.3;
      color: var(--text-color);
      font-family: {{ section.settings.card_title_font_family }};
      font-weight: {{ section.settings.card_title_font_weight }};
    }

    #{{ section_id }} .custom-image-card-text {
      margin: 0;
      font-size: var(--card-text-size);
      line-height: 1.5;
      color: var(--text-color);
      font-family: {{ section.settings.card_text_font_family }};
      font-weight: {{ section.settings.card_text_font_weight }};
      opacity: 0.9;
    }

    #{{ section_id }} .custom-image-card-button {
      display: inline-block;
      margin-top: 14px;
      padding: 10px 18px;
      border-radius: 999px;
      background: var(--button-bg);
      color: var(--button-color);
      font-size: 14px;
      line-height: 1;
      font-family: {{ section.settings.card_text_font_family }};
      font-weight: 600;
    }

    @media screen and (max-width: 989px) {
      #{{ section_id }} .custom-image-cards-list.is-grid {
        grid-template-columns: repeat({{ section.settings.cards_per_row_tablet }}, minmax(0, 1fr));
      }

      #{{ section_id }} .custom-image-cards-list.is-slider {
        grid-auto-columns: calc((100% - (var(--card-gap) * ({{ section.settings.slider_visible_tablet }} - 1))) / {{ section.settings.slider_visible_tablet }});
      }
    }

    @media screen and (max-width: 749px) {
      #{{ section_id }} {
        padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
        padding-left: {{ section.settings.padding_left_mobile }}px;
        padding-right: {{ section.settings.padding_right_mobile }}px;
      }

      #{{ section_id }} .custom-image-cards-heading {
        font-size: {{ section.settings.heading_size_mobile }}px;
      }

      #{{ section_id }} .custom-image-cards-description {
        font-size: {{ section.settings.description_size_mobile }}px;
      }

      #{{ section_id }} .custom-image-cards-list.is-grid {
        grid-template-columns: repeat(var(--cards-per-row-mobile), minmax(0, 1fr));
      }

      #{{ section_id }} .custom-image-cards-list.is-slider {
        grid-auto-columns: calc((100% - (var(--card-gap) * ({{ section.settings.slider_visible_mobile }} - 1))) / {{ section.settings.slider_visible_mobile }});
      }

      #{{ section_id }} .custom-image-card-title {
        font-size: {{ section.settings.card_title_size_mobile }}px;
      }

      #{{ section_id }} .custom-image-card-text {
        font-size: {{ section.settings.card_text_size_mobile }}px;
      }
    }
  </style>
</section>

