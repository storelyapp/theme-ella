  #{{ section_id }} .lagorii-faq-icon {
    position: relative;
    width: var(--faq-icon-size);
    height: var(--faq-icon-size);
    flex: 0 0 var(--faq-icon-size);
    color: var(--faq-icon-color);
  }

  #{{ section_id }} .lagorii-faq-icon-plus-v,
  #{{ section_id }} .lagorii-faq-icon-plus-h {
    position: absolute;
    left: 50%;
    top: 50%;
    background: currentColor;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    transition: opacity 0.25s ease;
  }

  #{{ section_id }} .lagorii-faq-icon-plus-h {
    width: var(--faq-icon-size);
    height: 1.6px;
  }

  #{{ section_id }} .lagorii-faq-icon-plus-v {
    width: 1.6px;
    height: var(--faq-icon-size);
  }

  #{{ section_id }} .lagorii-faq-item.is-open .lagorii-faq-icon-plus-v {
    opacity: 0;
  }

  #{{ section_id }} .lagorii-faq-answer-wrap {
    padding: 0 var(--faq-item-px) var(--faq-item-py);
  }

  #{{ section_id }} .lagorii-faq-answer {
