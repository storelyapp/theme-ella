  }

  #{{ section_id }} .lagorii-faq-title {
    margin: 0;
    color: var(--faq-heading-color);
    font-size: var(--faq-heading-size-desktop);
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0;
  }

  #{{ section_id }} .lagorii-faq-subtitle {
