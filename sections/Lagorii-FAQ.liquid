  #{{ section_id }} .lagorii-faq-item:first-child {
    border-top: 1px solid var(--faq-border-color);
  }

  #{{ section_id }} .lagorii-faq-question {
    width: 100%;
    border: 0;
    background: transparent;
    color: var(--faq-question-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    text-align: left;
    cursor: pointer;
    padding: var(--faq-item-py) var(--faq-item-px);
