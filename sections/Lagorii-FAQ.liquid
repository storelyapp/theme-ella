{% liquid
  assign section_id = 'lagorii-faq-' | append: section.id
%}

<section
  id="{{ section_id }}"
  class="lagorii-faq-section"
  style="
    --faq-bg: {{ section.settings.bg_color }};
    --faq-card-bg: {{ section.settings.card_bg_color }};
    --faq-heading-color: {{ section.settings.heading_color }};
    --faq-question-color: {{ section.settings.question_color }};
    --faq-answer-color: {{ section.settings.answer_color }};
    --faq-border-color: {{ section.settings.border_color }};
    --faq-icon-color: {{ section.settings.icon_color }};
    --faq-accent-color: {{ section.settings.accent_color }};
    --faq-max-width: {{ section.settings.content_width }}px;
    --faq-section-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --faq-section-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --faq-section-plr-desktop: {{ section.settings.padding_lr_desktop }}px;
    --faq-section-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --faq-section-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --faq-section-plr-mobile: {{ section.settings.padding_lr_mobile }}px;
    --faq-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --faq-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --faq-question-size-desktop: {{ section.settings.question_size_desktop }}px;
    --faq-question-size-mobile: {{ section.settings.question_size_mobile }}px;
    --faq-answer-size-desktop: {{ section.settings.answer_size_desktop }}px;
    --faq-answer-size-mobile: {{ section.settings.answer_size_mobile }}px;
    --faq-item-gap: {{ section.settings.item_gap }}px;
    --faq-item-py: {{ section.settings.item_padding_y }}px;
    --faq-item-px: {{ section.settings.item_padding_x }}px;
    --faq-answer-pt: {{ section.settings.answer_spacing_top }}px;
    --faq-icon-size: {{ section.settings.icon_size }}px;
    --faq-line-height: {{ section.settings.answer_line_height }};
    --faq-font-family: {{ section.settings.font_family }};
  "
>
  <div class="lagorii-faq-wrap">
    {% if section.settings.heading != blank %}
      <div class="lagorii-faq-header">
        <h2 class="lagorii-faq-title">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <div class="lagorii-faq-subtitle">{{ section.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div
      class="lagorii-faq-list"
      data-open-first="{{ section.settings.open_first_item }}"
      data-allow-multiple="{{ section.settings.allow_multiple_open }}"
    >
      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-1">
          <span class="lagorii-faq-question-text">Where is my order?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-1" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>You can track your order using the Track Order option on the Lagorii website. Once your order is shipped, a tracking link will be shared via SMS or email.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-2">
          <span class="lagorii-faq-question-text">How can I cancel my order?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-2" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Orders can be cancelled before they are shipped. Please contact our customer support team as soon as possible.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-3">
          <span class="lagorii-faq-question-text">How can I return my order?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-3" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>You can submit a return request through the Lagorii Returns Portal within the return window.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-4">
          <span class="lagorii-faq-question-text">How can I exchange my order?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-4" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Direct exchanges may not always be available. You can return the item and place a new order for the required size or product.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-5">
          <span class="lagorii-faq-question-text">Where is my refund?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-5" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Refunds are processed after the returned product passes the quality inspection.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-6">
          <span class="lagorii-faq-question-text">Money got deducted but order was not placed. What should I do?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-6" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>If the payment was deducted but the order was not confirmed, the amount is usually refunded automatically within 5–7 business days depending on your bank.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-7">
          <span class="lagorii-faq-question-text">My return is not picked up. What should I do?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-7" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>If your pickup is delayed, please contact our support team so we can assist you.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-8">
          <span class="lagorii-faq-question-text">My return is picked up but exchange order is not delivered.</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-8" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Exchange orders are processed after the returned item is inspected.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-9">
          <span class="lagorii-faq-question-text">How do I transfer money from wallet to bank account?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-9" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Lagorii wallet credits are typically used for purchases on the website and may not be transferable to bank accounts.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-10">
          <span class="lagorii-faq-question-text">I am not able to place an order.</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-10" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Please check your internet connection, payment method, and shipping address. If the issue continues, contact customer support.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-11">
          <span class="lagorii-faq-question-text">Within how many days can I return my order?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-11" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Returns must be requested within 3 days of delivery.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-12">
          <span class="lagorii-faq-question-text">How can I exchange for a different size?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-12" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Return the item and place a new order for the required size.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-13">
          <span class="lagorii-faq-question-text">What should I do if I receive a damaged product?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-13" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Please contact support within 24 hours of delivery with photos of the damaged item.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-14">
          <span class="lagorii-faq-question-text">I received the wrong item. What should I do?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-14" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Contact customer support immediately with images and your order details.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-15">
          <span class="lagorii-faq-question-text">I have requested a replacement. When will I receive it?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-15" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Replacement orders are shipped after the returned item passes inspection.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-16">
          <span class="lagorii-faq-question-text">Why is my pickup delayed?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-16" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Pickup delays may occur due to courier partner scheduling.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-17">
          <span class="lagorii-faq-question-text">Can I return all items?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-17" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Some products such as innerwear, socks, accessories, and clearance items may not be eligible for return.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-18">
          <span class="lagorii-faq-question-text">How do I get my refund for prepaid orders?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-18" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Refunds are processed to the original payment method or wallet credits.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-19">
          <span class="lagorii-faq-question-text">How do I get my refund for Cash on Delivery orders?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-19" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>COD refunds are issued as Lagorii wallet credits.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-20">
          <span class="lagorii-faq-question-text">Why was I charged for reverse pickup?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-20" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Return shipping charges may apply depending on the refund method and reason for return.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-21">
          <span class="lagorii-faq-question-text">How do I get my refund for discounted items?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-21" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Refunds for discounted products follow the same return policy with applicable deductions.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-22">
          <span class="lagorii-faq-question-text">What payment methods are accepted?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-22" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Lagorii accepts:</p>
            <ul>
              <li>UPI</li>
              <li>Credit Cards</li>
              <li>Debit Cards</li>
              <li>Net Banking</li>
              <li>Wallets</li>
              <li>Cash on Delivery</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-23">
          <span class="lagorii-faq-question-text">Is Cash on Delivery available?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-23" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Yes, Cash on Delivery is available for most locations.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-24">
          <span class="lagorii-faq-question-text">Is there a COD charge?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-24" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>A ₹100 COD handling charge is applied per order.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-25">
          <span class="lagorii-faq-question-text">My payment failed. What should I do?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-25" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Try placing the order again using another payment method.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-26">
          <span class="lagorii-faq-question-text">Is my payment secure?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-26" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Yes. All payments are processed through secure encrypted payment gateways.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-27">
          <span class="lagorii-faq-question-text">How do I choose the correct size for my child?</span>
          <span class="lagorii-faq-icon" aria-hidden="true">
            <span class="lagorii-faq-icon-plus-v"></span>
            <span class="lagorii-faq-icon-plus-h"></span>
          </span>
        </button>
        <div id="faq-answer-{{ section.id }}-27" class="lagorii-faq-answer-wrap" hidden>
          <div class="lagorii-faq-answer rte">
            <p>Use the size chart available on the product page.</p>
          </div>
        </div>
      </div>

      <div class="lagorii-faq-item">
        <button class="lagorii-faq-question" type="button" aria-expanded="false" aria-controls="faq-answer-{{ section.id }}-28">
