    }

    #{{ section_id }} .lagorii-faq-question {
      gap: 12px;
    }
  }
</style>

<script>
  (function() {
    function initLagoriiFaq(sectionId) {
      var section = document.getElementById(sectionId);
      if (!section) return;

      var faqList = section.querySelector('.lagorii-faq-list');
      if (!faqList || faqList.dataset.faqInitialized === 'true') return;

      faqList.dataset.faqInitialized = 'true';

      var openFirst = faqList.dataset.openFirst === 'true';
      var allowMultiple = faqList.dataset.allowMultiple === 'true';
      var items = faqList.querySelectorAll('.lagorii-faq-item');

      if (!items.length) return;

      function openItem(item) {
        var button = item.querySelector('.lagorii-faq-question');
        var answer = item.querySelector('.lagorii-faq-answer-wrap');
        if (!button || !answer) return;

        item.classList.add('is-open');
        button.setAttribute('aria-expanded', 'true');
        answer.hidden = false;
      }

      function closeItem(item) {
        var button = item.querySelector('.lagorii-faq-question');
        var answer = item.querySelector('.lagorii-faq-answer-wrap');
        if (!button || !answer) return;

        item.classList.remove('is-open');
        button.setAttribute('aria-expanded', 'false');
        answer.hidden = true;
      }

      items.forEach(function(item, index) {
        if (openFirst && index === 0) {
          openItem(item);
        } else {
          closeItem(item);
        }

        var button = item.querySelector('.lagorii-faq-question');
        if (!button) return;

        button.addEventListener('click', function() {
          var isOpen = item.classList.contains('is-open');

          if (!allowMultiple) {
            items.forEach(function(otherItem) {
              if (otherItem !== item) {
                closeItem(otherItem);
              }
            });
          }

          if (isOpen) {
            closeItem(item);
          } else {
            openItem(item);
          }
        });
      });
    }

    function runLagoriiFaqInit() {
      initLagoriiFaq('{{ section_id }}');
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', runLagoriiFaqInit);
    } else {
      runLagoriiFaqInit();
    }

    document.addEventListener('shopify:section:load', function(event) {
      var loadedSection = event.target;
      if (loadedSection && loadedSection.id === '{{ section_id }}') {
        initLagoriiFaq('{{ section_id }}');
      }
    });

    document.addEventListener('shopify:section:select', function(event) {
      var selectedSection = event.target;
      if (selectedSection && selectedSection.id === '{{ section_id }}') {
        initLagoriiFaq('{{ section_id }}');
      }
    });
  })();
</script>

