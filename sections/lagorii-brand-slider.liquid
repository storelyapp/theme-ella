{% comment %}
Lagorii – Category Slider (smooth)
- Horizontal image slider for categories
- Upload category image + link (collection or any URL)
- Native horizontal scroll (no snapping)
- Image-only cards (no extra text below)
{% endcomment %}

{% liquid
  assign inner_max = '1200px'
  case section.settings.section_width
    when '1170'
      assign inner_max = '1170px'
    when '1470'
      assign inner_max = '1470px'
    when '1770'
      assign inner_max = '1770px'
    when 'full'
      assign inner_max = '100%'
    else
      assign inner_max = '1200px'
  endcase
%}

<section
  id="lag-cat-slider-{{ section.id }}"
  class="lag-cat lag-cat--{{ section.settings.layout_mode }}"
  data-arrow-visibility="{{ section.settings.arrow_visibility }}"
  style="
    margin: {{ section.settings.section_margin_top | default: 24 }}px
            {{ section.settings.section_margin_right | default: 0 }}px
            {{ section.settings.section_margin_bottom | default: 24 }}px
            {{ section.settings.section_margin_left | default: 0 }}px;

    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% else %}
      background: {{ section.settings.bg | default: '#ffffff' }};
    {% endif %}
"
>
  <style>
    #lag-cat-slider-{{ section.id }} {
      --lag-cat-gap: {{ section.settings.gap | default: 16 }}px;
      --lag-cat-radius: {{ section.settings.radius | default: 16 }}px;

      /* Grid columns control */
      --lag-cat-grid-cols-desktop: {{ section.settings.grid_cols_desktop | default: 4 }};
      --lag-cat-grid-cols-mobile: {{ section.settings.grid_cols_mobile | default: 2 }};
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-inner {
      max-width: {{ inner_max }};
      margin: 0 auto;
      padding: {{ section.settings.inner_padding_top | default: 0 }}px
               {{ section.settings.inner_padding_right | default: 16 }}px
               {{ section.settings.inner_padding_bottom | default: 0 }}px
               {{ section.settings.inner_padding_left | default: 16 }}px;
    }

    /* Heading (center + styled) */
    #lag-cat-slider-{{ section.id }} .lag-cat-header {
      display: flex;
      justify-content: center;
      align-items: center;
      margin-bottom: 20px;
      text-align: center;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-heading {
      font-size: 28px;
      font-weight: 700;
      margin: 0;
      color: #E87529;
      letter-spacing: 0.5px;
      line-height: 1.2;
    }

    @media (max-width: 991px) {
      #lag-cat-slider-{{ section.id }} .lag-cat-heading { font-size: 24px; }
    }

    @media (max-width: 767px) {
      #lag-cat-slider-{{ section.id }} .lag-cat-heading { font-size: 20px; }
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-shell {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-viewport {
      position: relative;
      overflow-x: auto;
      overflow-y: visible;
      flex: 1 1 auto;
      -webkit-overflow-scrolling: touch;
      scroll-behavior: smooth;

      /* how many cards visible – used only for flex sizing */
      --lag-cat-visible: {{ section.settings.visible_desktop | default: 5 }};
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-viewport::-webkit-scrollbar {
      display: none;
    }

    @media (max-width: 991px) {
      #lag-cat-slider-{{ section.id }} .lag-cat-viewport {
        --lag-cat-visible: {{ section.settings.visible_tablet | default: 3 }};
      }
    }

    @media (max-width: 767px) {
      #lag-cat-slider-{{ section.id }} .lag-cat-viewport {
        --lag-cat-visible: {{ section.settings.visible_mobile | default: 3 }};
      }
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-track {
      display: flex;
      align-items: stretch;
      gap: var(--lag-cat-gap);
      will-change: transform;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-slide {
      flex: 0 0 calc(
        (100% - (var(--lag-cat-visible) - 1) * var(--lag-cat-gap))
        / var(--lag-cat-visible)
      );
      display: flex;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-card {
      display: flex;
      width: 100%;
      border-radius: var(--lag-cat-radius);
      overflow: hidden;
      background: transparent;
      text-decoration: none;
      color: inherit;
      box-shadow: none;
      transition: none;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-image-wrap {
      position: relative;
      width: 100%;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-image-wrap img {
      display: block;
      width: 100%;
      height: auto;
      object-fit: cover;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-arrow {
      border: none;
      background: #ffffff;
      border-radius: 999px;
      width: 32px;
      height: 32px;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 0;
      cursor: pointer;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-arrow svg {
      width: 16px;
      height: 16px;
    }

    @media (max-width: 767px) {
      #lag-cat-slider-{{ section.id }}[data-arrow-visibility="mobile"] .lag-cat-arrow,
      #lag-cat-slider-{{ section.id }}[data-arrow-visibility="both"] .lag-cat-arrow {
        display: inline-flex;
      }
    }

    @media (min-width: 768px) {
      #lag-cat-slider-{{ section.id }}[data-arrow-visibility="desktop"] .lag-cat-arrow,
      #lag-cat-slider-{{ section.id }}[data-arrow-visibility="both"] .lag-cat-arrow {
        display: inline-flex;
      }
    }

    /* Dots */
    #lag-cat-slider-{{ section.id }} .lag-cat-dots {
      display: flex;
      justify-content: center;
      gap: 6px;
      margin-top: 10px;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-dot {
      width: 6px;
      height: 6px;
      border-radius: 999px;
      border: none;
      padding: 0;
      background: {{ section.settings.dot_color }};
      cursor: pointer;
      transition: all 0.25s ease;
    }

    #lag-cat-slider-{{ section.id }} .lag-cat-dot.is-active {
      width: 14px;
      background: {{ section.settings.dot_active_color }};
    }

    /* =========================
       GRID MODE (toggle + columns)
    ========================= */
    #lag-cat-slider-{{ section.id }}.lag-cat--grid .lag-cat-viewport {
      overflow: visible;
    }

    #lag-cat-slider-{{ section.id }}.lag-cat--grid .lag-cat-track {
      display: grid;
      grid-template-columns: repeat(var(--lag-cat-grid-cols-desktop), minmax(0, 1fr));
      gap: var(--lag-cat-gap);
      will-change: auto;
    }

    #lag-cat-slider-{{ section.id }}.lag-cat--grid .lag-cat-slide {
      flex: unset;
    }

    /* Mobile columns */
    @media (max-width: 767px) {
      #lag-cat-slider-{{ section.id }}.lag-cat--grid .lag-cat-track {
        grid-template-columns: repeat(var(--lag-cat-grid-cols-mobile), minmax(0, 1fr));
      }
    }

    #lag-cat-slider-{{ section.id }}.lag-cat--grid .lag-cat-arrow,
    #lag-cat-slider-{{ section.id }}.lag-cat--grid .lag-cat-dots {
      display: none !important;
    }
  </style>

  <div class="lag-cat-inner">
    {% if section.settings.show_heading and section.settings.heading != blank %}
      <div class="lag-cat-header">
        <h2 class="lag-cat-heading">
          {{ section.settings.heading }}
        </h2>
      </div>
    {% endif %}

    {% assign blocks_count = section.blocks | size %}

    {% if blocks_count > 0 %}
      <div class="lag-cat-shell">
        <button
          type="button"
          class="lag-cat-arrow"
          data-lag-cat-prev
          aria-label="Previous category"
        >
          <svg viewBox="0 0 20 20" aria-hidden="true">
            <path d="M12.7 15.3a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 0-1.4l4-4a1 1 0 1 1 1.4 1.4L9.41 10l3.29 3.29a1 1 0 0 1 0 1.41z" fill="currentColor"/>
          </svg>
        </button>

        <div class="lag-cat-viewport">
          <div class="lag-cat-track">
            {% for block in section.blocks %}
              {% if block.type == 'category' %}
                {% assign link_url = block.settings.link | default: block.settings.collection.url %}
                {% if link_url == blank %}
                  {% assign link_url = '#' %}
                {% endif %}

                <div class="lag-cat-slide" {{ block.shopify_attributes }}>
                  <a
                    href="{{ link_url }}"
                    class="lag-cat-card"
                    aria-label="{{ block.settings.title | default: 'Category' | escape }}"
                  >
                    <div class="lag-cat-image-wrap">
                      {% if block.settings.image != blank %}
                        {% assign img = block.settings.image %}
                        <img
                          src="{{ img | image_url: width: 900 }}"
                          srcset="
                            {{ img | image_url: width: 480 }} 480w,
                            {{ img | image_url: width: 720 }} 720w,
                            {{ img | image_url: width: 960 }} 960w
                          "
                          sizes="(max-width: 767px) 90vw, (max-width: 991px) 60vw, 360px"
                          alt="{{ block.settings.title | default: img.alt | escape }}"
                          loading="lazy"
                        >
                      {% else %}
                        <div style="padding: 40px 12px; text-align:center; font-size: 13px;">
                          Upload category image
                        </div>
                      {% endif %}
                    </div>
                  </a>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <button
          type="button"
          class="lag-cat-arrow"
          data-lag-cat-next
          aria-label="Next category"
        >
          <svg viewBox="0 0 20 20" aria-hidden="true">
            <path d="M7.3 4.7a1 1 0 0 1 1.4 0l4 4a1 1 0 0 1 0 1.4l-4 4a1 1 0 1 1-1.4-1.4L10.59 10 7.3 6.71a1 1 0 0 1 0-1.41z" fill="currentColor"/>
          </svg>
        </button>
      </div>

      {% if section.settings.show_dots %}
        <div class="lag-cat-dots" data-lag-cat-dots>
          {% for block in section.blocks %}
            {% if block.type == 'category' %}
              <button
                type="button"
                class="lag-cat-dot{% if forloop.first %} is-active{% endif %}"
                data-index="{{ forloop.index0 }}"
                aria-label="Go to slide {{ forloop.index }}"
              ></button>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}
  </div>

  <script>
    (function() {
      var root = document.getElementById('lag-cat-slider-{{ section.id }}');
      if (!root) return;

      if (root.classList.contains('lag-cat--grid')) return;

      var viewport = root.querySelector('.lag-cat-viewport');
      var track = root.querySelector('.lag-cat-track');
      if (!viewport || !track) return;

      var slides = Array.prototype.slice.call(track.children || []);
      if (!slides.length) return;

      var autoplay = {{ section.settings.autoplay | json }};
      var interval = {{ section.settings.autoplay_interval | times: 1000 }};
      var autoplayTimer = null;

      var dotsContainer = root.querySelector('[data-lag-cat-dots]');
      var dots = dotsContainer ? Array.prototype.slice.call(dotsContainer.querySelectorAll('.lag-cat-dot')) : [];

      function getSlideSize() {
        if (!slides.length) return 0;
        var rect = slides[0].getBoundingClientRect();
        var style = window.getComputedStyle(track);
        var gap = parseFloat(style.columnGap || style.gap) || 0;
        return rect.width + gap;
      }

      function scrollBySlides(count) {
        var size = getSlideSize();
        if (!size) return;
        viewport.scrollBy({
          left: size * count,
          behavior: 'smooth'
        });
      }

      function scrollToIndex(idx) {
        var size = getSlideSize();
        if (!size) return;
        viewport.scrollTo({
          left: size * idx,
          behavior: 'smooth'
        });
      }

      function updateDots() {
        if (!dots.length) return;
        var size = getSlideSize();
        if (!size) return;
        var idx = Math.round(viewport.scrollLeft / size);
        if (idx < 0) idx = 0;
        if (idx >= dots.length) idx = dots.length - 1;
        dots.forEach(function(dot, i) {
          dot.classList.toggle('is-active', i === idx);
        });
      }

      var prevBtn = root.querySelector('[data-lag-cat-prev]');
      var nextBtn = root.querySelector('[data-lag-cat-next]');

      if (prevBtn) {
        prevBtn.addEventListener('click', function(e) {
          e.preventDefault();
          scrollBySlides(-1);
          resetAutoplay();
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', function(e) {
          e.preventDefault();
          scrollBySlides(1);
          resetAutoplay();
        });
      }

      if (dots.length) {
        dots.forEach(function(dot) {
          dot.addEventListener('click', function() {
            var idx = parseInt(dot.getAttribute('data-index') || '0', 10);
            scrollToIndex(idx);
            resetAutoplay();
          });
        });
      }

      viewport.addEventListener('scroll', function() {
        updateDots();
      });

      function startAutoplay() {
        if (!autoplay || !slides.length) return;
        clearInterval(autoplayTimer);
        autoplayTimer = setInterval(function() {
          var size = getSlideSize();
          if (!size) return;
          var maxScroll = viewport.scrollWidth - viewport.clientWidth - 5;
          if (viewport.scrollLeft >= maxScroll) {
            viewport.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            scrollBySlides(1);
          }
        }, interval);
      }

      function resetAutoplay() {
        if (!autoplay) return;
        clearInterval(autoplayTimer);
        startAutoplay();
      }

      startAutoplay();
    })();
  </script>
</section>

{% schema %}
{
  "name": "Lag Category slider",
  "settings": [
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout mode",
      "default": "slider",
      "options": [
        { "value": "slider", "label": "Slider" },
        { "value": "grid", "label": "Grid" }
      ]
    },
    {
      "type": "range",
      "id": "grid_cols_desktop",
      "label": "Grid columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "grid_cols_mobile",
      "label": "Grid columns (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width (desktop)",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "1170", "label": "1170px" },
        { "value": "1470", "label": "1470px" },
        { "value": "1770", "label": "1770px" },
        { "value": "full", "label": "Full width" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "select",
      "id": "visible_desktop",
      "label": "Cards visible (desktop)",
      "default": "5",
      "options": [
        { "value": "5", "label": "5" },
        { "value": "5.5", "label": "5.5" },
        { "value": "6", "label": "6" },
        { "value": "6.5", "label": "6.5" }
      ]
    },
    {
      "type": "select",
      "id": "visible_tablet",
      "label": "Cards visible (tablet)",
      "default": "3",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "3.5", "label": "3.5" },
        { "value": "4", "label": "4" },
        { "value": "4.5", "label": "4.5" },
        { "value": "5", "label": "5" }
      ]
    },
    {
      "type": "select",
      "id": "visible_mobile",
      "label": "Cards visible (mobile)",
      "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "2.5", "label": "2.5" },
        { "value": "3", "label": "3" },
        { "value": "3.5", "label": "3.5" },
        { "value": "4", "label": "4" },
        { "value": "4.5", "label": "4.5" }
      ]
    },
    {
      "type": "select",
      "id": "arrow_visibility",
      "label": "Show arrows",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "mobile", "label": "Mobile only" },
        { "value": "desktop", "label": "Desktop only" },
        { "value": "both", "label": "Mobile & desktop" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dots color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Active dot color",
      "default": "#E87529"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Autoplay interval (seconds)",
      "min": 3,
      "max": 20,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Card corner radius (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "color",
      "id": "bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "section_margin_top",
      "label": "Margin top (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "section_margin_right",
      "label": "Margin right (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "section_margin_bottom",
      "label": "Margin bottom (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "section_margin_left",
      "label": "Margin left (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "inner_padding_top",
      "label": "Inner padding top (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "inner_padding_right",
      "label": "Inner padding right (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "inner_padding_bottom",
      "label": "Inner padding bottom (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "inner_padding_left",
      "label": "Inner padding left (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Category image" },
        { "type": "collection", "id": "collection", "label": "Collection (optional)" },
        { "type": "url", "id": "link", "label": "Custom URL (overrides collection)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Category name" },
        { "type": "text", "id": "subtext", "label": "Subtext" }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Lag Category slider",
      "category": "Lagorii"
    }
  ]
}
{% endschema %}