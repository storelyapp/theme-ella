}

/* Cards per row — controlled only by data-cpr */
#lg-pay-{{ section.id }} .grid{ grid-template-columns: repeat(12,1fr); }

/* Default desktop/tablet = 2 per row */
@media (min-width: 900px){
  #lg-pay-{{ section.id }} .lg-pay__card{ grid-column: span 6; }        /* 12/6 = 2 per row */
}
/* If the setting chooses 3 per row */
@media (min-width: 900px){
  #lg-pay-{{ section.id }}[data-cpr="3"] .lg-pay__card{ grid-column: span 4; }  /* 12/4 = 3 */
}
/* If the setting chooses 4 per row */
@media (min-width: 1200px){
  #lg-pay-{{ section.id }}[data-cpr="4"] .lg-pay__card{ grid-column: span 3; }  /* 12/3 = 4 */
}

/* Mobile: full width */
@media (max-width: 899.98px){
  #lg-pay-{{ section.id }} .lg-pay__card{ grid-column: span 12; }
}

