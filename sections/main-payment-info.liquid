<script>
  (function(){
    const root = document.getElementById('lg-pay-{{ section.id }}');
    if(!root) return;

    // Buttons (desktop + mobile) — no invoices now
    const tabButtons = [
      root.querySelector('#btn-methods-{{ section.id }}'),
      root.querySelector('#btn-security-{{ section.id }}'),
      root.querySelector('#btn-gift-{{ section.id }}'),
      root.querySelector('#m-btn-methods-{{ section.id }}'),
      root.querySelector('#m-btn-security-{{ section.id }}'),
      root.querySelector('#m-btn-gift-{{ section.id }}')
    ].filter(Boolean);

    // Panels — no invoices
    const panels = {
      methods: root.querySelector('#tab-methods-{{ section.id }}'),
      security: root.querySelector('#tab-security-{{ section.id }}'),
      gift:     root.querySelector('#tab-gift-{{ section.id }}')
    };

    function setActive(which){
      Object.keys(panels).forEach(k => panels[k] && panels[k].classList.toggle('is-active', k===which));
      tabButtons.forEach(btn => {
        const id = (btn.id.includes('methods') ? 'methods'
                 : btn.id.includes('security') ? 'security'
                 : 'gift');
        btn.classList.toggle('is-active', id===which);
        btn.setAttribute('aria-selected', id===which ? 'true' : 'false');
      });
    }

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const which = (btn.id.includes('methods') ? 'methods'
                    : btn.id.includes('security') ? 'security'
                    : 'gift');
        history.replaceState(null,'', '#'+which);
        setActive(which);
      });
    });

    const hash = (location.hash||'').replace('#','');
    if(['methods','security','gift'].includes(hash)){ setActive(hash); }
    else { setActive('methods'); }
  })();
</script>

