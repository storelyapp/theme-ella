{% comment %} Gift Card Lookup (minimal) {% endcomment %}

<div class="gc-lookup-wrap">
  <div class="gc-pane" id="gc-lookup">
    <div class="giftcard-lookup">

      <!-- Page title -->
      <h1 class="gc-title">{{ page.title | default: 'Check Gift Card Balance' }}</h1>

      <!-- Lookup form -->
    <form class="gc-form" id="gcLookupForm" novalidate>
      <div class="gc-field">
        <label for="gcEmail">Email</label>
        <input id="gcEmail" name="email" type="email" inputmode="email" placeholder="you@example.com" required>
      </div>
      <div class="gc-field gc-field--last4">
        <label for="gcLast4">Gift Card (Last 4 digits)</label>
        <input id="gcLast4" name="last4" type="text" inputmode="text" maxlength="4" pattern="[0-9A-Za-z]{4}" placeholder="AB12" required>
      </div>
      <div class="gc-submit-wrap">
        <button class="gc-btn" type="submit">Check balance</button>
      </div>
      <p class="gc-help"><small>We only need the last 4 digits for security.</small></p>
    </form>

      <!-- Results (hidden until submit) -->
      <div id="creditsList" class="gc-list" hidden></div>

    <button type="button" class="gc-back is-hidden" id="gcBack" aria-label="Go back">
  <svg class="gc-back-icon" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
    <!-- circle outline -->
    <circle cx="12" cy="12" r="10" />
    <!-- chevron left -->
    <polyline points="13 8 9 12 13 16" />
    <line x1="16" y1="12" x2="9" y2="12" />
  </svg>
  Back
</button>

    </div>
  </div>

  <style>
    :root{ --lag-brand:#E87529; }

    /* Page container */
    .gc-lookup-wrap{
      padding: 24px 16px;
    }
    .giftcard-lookup{
      max-width: 960px;
      margin: 0 auto;
    }

    /* Title */
    .gc-title{
      margin: 0 0 14px;
      font-size: 22px;
      line-height: 1.25;
      letter-spacing: .2px;
    }

    /* Form (minimal) */
    .gc-form{
      display:grid;
      grid-template-columns: 1fr 180px 160px;
      gap: 12px;
      align-items:end;
      margin: 8px 0 12px;
    }
    .gc-field label{
      display:block; font-size:12px; opacity:.75; margin-bottom:6px;
    }
    .gc-field input{
      width:100%; height:44px; padding:0 12px; background:#fff; outline:none;
      border:1px solid rgba(0,0,0,.12); border-radius:10px;
    }
    .gc-field input:focus{
      border-color:var(--lag-brand);
      box-shadow:0 0 0 3px color-mix(in srgb, var(--lag-brand) 20%, transparent);
    }
    .gc-btn{
      height:44px; border-radius:10px; border:0; cursor:pointer;
      background:var(--lag-brand); color:#fff; font-weight:600; padding:0 14px;
      transition:transform .06s ease, filter .18s ease;
    }
    .gc-btn:hover{ filter:brightness(.96); }
    .gc-btn:active{ transform:translateY(1px); }
    .gc-help{ grid-column:1 / -1; margin:2px 0 0; opacity:.65; }

    /* Back button */
    .gc-back{
      appearance:none; background:transparent; border:0; padding:0;
      color:var(--lag-brand); font-weight:600; cursor:pointer;
      margin: 6px 0 10px; /* appears above the list when visible */
    }
    .gc-back.is-hidden{ display:none; }

    /* Results list (simple cards) */
    .gc-list{ display:grid; gap:12px; }
    .gc-card{
      border:1px solid rgba(0,0,0,.08);
      border-radius:12px;
      background:#fff;
      padding:12px 14px;
      box-shadow:0 2px 10px rgba(0,0,0,.03);
    }
    .gc-card-head{
      display:flex; align-items:center; justify-content:space-between; gap:12px;
      margin-bottom:6px;
    }
    .gc-card-title{ font-weight:700; }
    .gc-pill{
      font-size:12px; background:#f5f5f5; padding:4px 8px; border-radius:999px;
    }
    .gc-usage{ height:6px; background:#f1f1f1; border-radius:999px; overflow:hidden; margin:6px 0; }
    .gc-usage-bar{ height:100%; background:var(--lag-brand); width:0; transition:width .3s ease; }
    .gc-usage-legend{ display:flex; justify-content:space-between; font-size:12px; opacity:.7; }
    .gc-row{ display:flex; justify-content:space-between; gap:10px; padding:4px 0; font-size:13px; }
    .gc-status .badge{ padding:2px 8px; border-radius:999px; font-size:12px; }
    .badge.good{ background:rgba(4,166,80,.12); color:#069455; }
    .badge.bad{ background:rgba(220,60,60,.12); color:#C12727; }

    /* Utilities */
    .is-hidden{ display:none !important; }

    /* Responsive */
    @media (max-width: 900px){
      .gc-form{ grid-template-columns: 1fr 140px; }
      .gc-btn{ grid-column: span 2; }
    }

