}
  </style>

<script>
(() => {
  const API_BASE = 'https://store-credit-576084571817.us-central1.run.app/public/store-credits';
  const $ = (s, r = document) => r.querySelector(s);

  const form     = $('#gcLookupForm');
  const emailEl  = $('#gcEmail');
  const last4El  = $('#gcLast4');
  const listPane = $('#creditsList');
  const backBtn  = $('#gcBack');

  const MONEY_FMT = {{ shop.money_format | json }};
  const moneyHTML = (majorUnits, cur) => {
    const rupees = Number(majorUnits || 0);
    const minor = Math.round(rupees * 100);
    try {
      return Shopify.formatMoney(minor, MONEY_FMT);
    } catch {
      try {
        return new Intl.NumberFormat('en-IN', { style: 'currency', currency: (cur || 'INR') }).format(rupees);
      } catch {
        return (cur || 'INR') + ' ' + rupees.toFixed(2);
      }
    }
  };

  const daysLeft = (d) => {
    if (!d) return null;
    const now = new Date();
    const end = new Date(d + 'T23:59:59Z');
    return Math.ceil((end - now) / 86400000);
  };

  {% if customer and customer.email %}
    if (emailEl) emailEl.value = {{ customer.email | json }};
  {% endif %}

  const hide = (el) => el && (el.hidden = true);
  const show = (el) => el && (el.hidden = false);

  function setLoading() {
    show(listPane);
    listPane.innerHTML = '<p>Fetching your gift cards…</p>';
  }

  function render(cards) {
    // Show an empty state if nothing matched
    if (!Array.isArray(cards) || !cards.length) {
      listPane.innerHTML = '<p>No matching gift cards were found for those details.</p>';
      return;
    }

    // helper: treat these as "not usable"
    const isInactive = (status) => {
      const s = String(status || '').toLowerCase();
      return s === 'expired' || s === 'deactivated' || s === 'inactive' || s === 'disabled';
    };

    // Compute total unusable (expired/deactivated) amount across the shown cards
    let totalInactive = 0;
    let currency = cards[0]?.currency || 'INR';
    cards.forEach(c => {
      if (isInactive(c.status)) totalInactive += Number(c.balanceAmount || 0);
    });

    // Build optional red summary line
    const summaryHTML = totalInactive > 0
      ? `<div class="gc-expired-summary">Expired/Deactivated: <span class="gc-amt-bad">${moneyHTML(totalInactive, currency)}</span></div>`
      : '';

    // Cards list
    listPane.classList.add('gc-list');
    listPane.innerHTML =
      summaryHTML +
      cards.map((c) => {
        const init = Number(c.initialAmount || 0);
        const bal  = Number(c.balanceAmount || 0);
        const used = Math.max(0, init - bal);
        const pct  = init > 0 ? Math.round((used / init) * 100) : 0;

        const d  = daysLeft(c.expiresOn);
        const expiry = c.expiresOn
          ? `${c.expiresOn} (${Math.abs(d)} day${Math.abs(d) === 1 ? '' : 's'} ${d >= 0 ? 'left' : 'past'})`
          : 'No expiry';

        const last4 = String(c.lastCharacters || '----').toUpperCase();
        const inactive = isInactive(c.status);

        return `
          <div class="gc-card">
            <div class="gc-card-head">
              <div class="gc-card-title">Gift Card</div>
              <div class="gc-pill">•••• ${last4}</div>
            </div>

            <div class="gc-usage">
              <div class="gc-usage-bar" style="width:${Math.min(100, Math.max(0, pct))}%"></div>
            </div>
            <div class="gc-usage-legend">
              <span>Used ${pct}%</span>
              <span>Remaining ${100 - pct}%</span>
            </div>

            <div class="gc-row"><span>Initial</span><span>${moneyHTML(init, c.currency)}</span></div>
            <div class="gc-row"><span>Used so far</span><span>${moneyHTML(used, c.currency)}</span></div>

            <!-- If inactive, hide the numeric balance (show an em dash) -->
            <div class="gc-row"><span>Balance</span><span>${inactive ? '—' : moneyHTML(bal, c.currency)}</span></div>

            <div class="gc-row"><span>Issued on</span><span>${c.createdAt || '-'}</span></div>
            <div class="gc-row"><span>Expires on</span><span>${expiry}</span></div>

            <div class="gc-row gc-status">
              <span>Status</span>
              <span class="badge ${inactive ? 'bad' : 'good'}">${c.status || '—'}</span>
            </div>
          </div>`;
      }).join('');
  }

  async function fetchByEmailLast4(email, last4) {
    const url = `${API_BASE}?email=${encodeURIComponent(email.trim())}&last4=${encodeURIComponent(last4.trim())}`;
    const res = await fetch(url, { headers: { Accept: 'application/json' } });
    const txt = await res.text();
    try { return JSON.parse(txt); } catch { return { error: 'bad_json' }; }
  }

  function validate() {
    const email = (emailEl?.value || '').trim();
    const last4 = (last4El?.value || '').trim().toUpperCase();
    if (!email || !/^\S+@\S+\.\S+$/.test(email)) return { ok:false, msg:'Please enter a valid email.' };
    if (!last4 || last4.length !== 4) return { ok:false, msg:'Please enter the last 4 characters of your code.' };
    return { ok:true, email, last4 };
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const v = validate();
    if (!v.ok) {
      // Client-side validation errors: keep form visible; do NOT show back button
      show(listPane);
      listPane.innerHTML = `<p>${v.msg}</p>`;
      return;
    }

    // Hide form; show results pane + back button
    form.classList.add('is-hidden');
    setLoading();

    try {
      const data  = await fetchByEmailLast4(v.email, v.last4);
      const cards = Array.isArray(data?.cards) ? data.cards : [];

      // Ensure we only display the card that matches the entered last4
      const filtered = cards.filter(c => String(c.lastCharacters || '')
        .slice(-4)
        .toUpperCase() === v.last4);

      render(filtered);
    } catch {
      listPane.innerHTML = '<p>We couldn’t fetch your gift card details. Please try again later.</p>';
    } finally {
      backBtn?.classList.remove('is-hidden');  // show Back for success OR server error
      show(listPane);
    }
  });

  backBtn?.addEventListener('click', () => {
    // Reset to pristine state
    hide(listPane);
    listPane.innerHTML = '';
    form.classList.remove('is-hidden');
    backBtn.classList.add('is-hidden');
    form.reset();
    emailEl?.focus();
  });

  // Initial state
  hide(listPane);
})();
</script>
</div>

