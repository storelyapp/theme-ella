{% comment %}
  Lagorii Coupon Copy Slider
  Mobile only
  Add multiple cards as blocks
  Auto sliding cards
{% endcomment %}

<section class="lag-coupon-slider lag-coupon-slider--{{ section.id }}">
  <style>
    .lag-coupon-slider--{{ section.id }}{
      padding-top: {{ section.settings.section_padding_top }}px;
      padding-bottom: {{ section.settings.section_padding_bottom }}px;
    }

    @media (min-width: 990px){
      .lag-coupon-slider--{{ section.id }}{
        display: none !important;
      }
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon-slider__outer{
      padding: {{ section.settings.outer_pad_top }}px {{ section.settings.outer_pad_right }}px {{ section.settings.outer_pad_bottom }}px {{ section.settings.outer_pad_left }}px;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon-slider__viewport{
      overflow: hidden;
      width: 100%;
      position: relative;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon-slider__track{
      display: flex;
      transition: transform 0.45s ease;
      will-change: transform;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon-slider__slide{
      min-width: 100%;
      width: 100%;
      flex: 0 0 100%;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__mobile-image-wrap{
      width: 100%;
      line-height: 0;
      overflow: hidden;
      border-radius: {{ section.settings.image_radius }}px;
      background: {{ section.settings.image_bg_color }};
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__mobile-image{
      width: 100%;
      height: auto;
      display: block;
      object-fit: contain;
      object-position: center;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__card{
      position: relative;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: {{ section.settings.card_gap }}px;
      padding: {{ section.settings.card_pad_top }}px {{ section.settings.card_pad_right }}px {{ section.settings.card_pad_bottom }}px {{ section.settings.card_pad_left }}px;
      border-radius: {{ section.settings.card_radius }}px;
      border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
      box-shadow: {{ section.settings.card_shadow }};
      background-color: {{ section.settings.card_bg_color }};
      font-family: {{ section.settings.font_family }};
      overflow: hidden;
      min-height: {{ section.settings.card_min_height }}px;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__left{
      display: flex;
      align-items: center;
      gap: {{ section.settings.left_gap }}px;
      min-width: 0;
      flex: 1 1 auto;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__badge{
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: {{ section.settings.badge_pad_y }}px {{ section.settings.badge_pad_x }}px;
      border-radius: {{ section.settings.badge_radius }}px;
      border: {{ section.settings.badge_border_width }}px dashed {{ section.settings.badge_border_color }};
      background: {{ section.settings.badge_bg_color }};
      color: {{ section.settings.badge_text_color }};
      flex: 0 0 auto;
      user-select: none;
      white-space: nowrap;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__badge-text{
      font-size: {{ section.settings.badge_font_size }}px;
      font-weight: {{ section.settings.badge_font_weight }};
      letter-spacing: 0.3px;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__title{
      margin: 0;
      color: {{ section.settings.title_color }};
      font-size: {{ section.settings.title_size_mobile }}px;
      font-weight: {{ section.settings.title_weight }};
      line-height: 1.2;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__subtitle{
      margin: {{ section.settings.subtitle_margin_top }}px 0 0 0;
      color: {{ section.settings.subtitle_color }};
      font-size: {{ section.settings.subtitle_size_mobile }}px;
      font-weight: {{ section.settings.subtitle_weight }};
      line-height: 1.35;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__copy{
      appearance: none;
      border: {{ section.settings.copy_border_width }}px solid {{ section.settings.copy_border_color }};
      background: {{ section.settings.copy_bg }};
      color: {{ section.settings.copy_color }};
      border-radius: {{ section.settings.copy_radius }}px;
      padding: {{ section.settings.copy_pad_y_mobile }}px {{ section.settings.copy_pad_x_mobile }}px;
      font-family: {{ section.settings.font_family }};
      font-size: {{ section.settings.copy_font_size_mobile }}px;
      font-weight: {{ section.settings.copy_font_weight }};
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      line-height: 1;
      white-space: nowrap;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__copy svg{
      width: {{ section.settings.copy_icon_size }}px;
      height: {{ section.settings.copy_icon_size }}px;
      display: block;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__toast{
      position: absolute;
      right: 14px;
      top: 14px;
      background: {{ section.settings.toast_bg }};
      color: {{ section.settings.toast_color }};
      border-radius: {{ section.settings.toast_radius }}px;
      padding: {{ section.settings.toast_pad_y }}px {{ section.settings.toast_pad_x }}px;
      font-size: {{ section.settings.toast_font_size }}px;
      font-weight: {{ section.settings.toast_font_weight }};
      opacity: 0;
      transform: translateY(-6px);
      pointer-events: none;
      transition: opacity .18s ease, transform .18s ease;
      z-index: 2;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon__toast.is-visible{
      opacity: 1;
      transform: translateY(0);
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon-slider__dots{
      display: flex;
      justify-content: center;
      gap: 6px;
      margin-top: {{ section.settings.dots_margin_top }}px;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon-slider__dot{
      width: {{ section.settings.dot_size }}px;
      height: {{ section.settings.dot_size }}px;
      border-radius: 50%;
      background: {{ section.settings.dot_color }};
      opacity: .35;
      border: 0;
      padding: 0;
    }

    .lag-coupon-slider--{{ section.id }} .lag-coupon-slider__dot.is-active{
      opacity: 1;
      background: {{ section.settings.dot_active_color }};
    }
  </style>

  <div class="page-width">
    <div class="lag-coupon-slider__outer">
      <div class="lag-coupon-slider__viewport">
        <div class="lag-coupon-slider__track">
          {% for block in section.blocks %}
            <div class="lag-coupon-slider__slide" {{ block.shopify_attributes }}>
              {% if block.settings.coupon_display_mode == 'image' %}
                {% if block.settings.mobile_banner_image != blank %}
                  <div class="lag-coupon__mobile-image-wrap">
                    <img
                      class="lag-coupon__mobile-image"
                      src="{{ block.settings.mobile_banner_image | image_url: width: 1400 }}"
                      alt="{{ block.settings.mobile_banner_alt | escape }}"
                      loading="lazy"
                      width="{{ block.settings.mobile_banner_image.width }}"
                      height="{{ block.settings.mobile_banner_image.height }}"
                    >
                  </div>
                {% endif %}
              {% else %}
                <div class="lag-coupon__card" role="region" aria-label="Coupon">
                  <div class="lag-coupon__left">
                    {% if block.settings.show_badge %}
                      <div class="lag-coupon__badge">
                        <span class="lag-coupon__badge-text">{{ block.settings.badge_text }}</span>
                      </div>
                    {% endif %}

                    <div class="lag-coupon__text">
                      {% if block.settings.title != blank %}
                        <p class="lag-coupon__title">{{ block.settings.title }}</p>
                      {% endif %}
                      {% if block.settings.subtitle != blank %}
                        <p class="lag-coupon__subtitle">{{ block.settings.subtitle }}</p>
                      {% endif %}
                    </div>
                  </div>

                  {% if section.settings.show_copy_button %}
                    <div class="lag-coupon__right">
                      <button
                        class="lag-coupon__copy"
                        type="button"
                        data-coupon-code="{{ block.settings.coupon_code | escape }}"
                        aria-label="Copy coupon code"
                      >
                        <span class="lag-coupon__code">{{ block.settings.coupon_code }}</span>
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                          <path d="M16 1H6a2 2 0 0 0-2 2v12h2V3h10V1zm3 4H10a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm0 16H10V7h9v14z"></path>
                        </svg>
                      </button>
                    </div>
                  {% endif %}

                  <div class="lag-coupon__toast" aria-live="polite">{{ section.settings.toast_text }}</div>
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>

      {% if section.settings.show_dots and section.blocks.size > 1 %}
        <div class="lag-coupon-slider__dots">
          {% for block in section.blocks %}
            <button class="lag-coupon-slider__dot{% if forloop.first %} is-active{% endif %}" type="button" aria-label="Go to coupon {{ forloop.index }}"></button>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>

  <script>
    (function(){
      var root = document.querySelector('.lag-coupon-slider--{{ section.id }}');
      if(!root) return;

      var track = root.querySelector('.lag-coupon-slider__track');
      var slides = root.querySelectorAll('.lag-coupon-slider__slide');
      var dots = root.querySelectorAll('.lag-coupon-slider__dot');
      var index = 0;
      var timer = null;
      var speed = {{ section.settings.autoplay_speed }};
      var autoplay = {{ section.settings.enable_autoplay | json }};

      function goToSlide(i){
        if(!track || slides.length === 0) return;
        index = i;
        track.style.transform = 'translateX(-' + (index * 100) + '%)';

        dots.forEach(function(dot, dotIndex){
          dot.classList.toggle('is-active', dotIndex === index);
        });
      }

      function nextSlide(){
        var next = index + 1;
        if(next >= slides.length) next = 0;
        goToSlide(next);
      }

      function startAutoplay(){
        if(!autoplay || slides.length <= 1) return;
        stopAutoplay();
        timer = window.setInterval(nextSlide, speed);
      }

      function stopAutoplay(){
        if(timer) window.clearInterval(timer);
      }

      dots.forEach(function(dot, dotIndex){
        dot.addEventListener('click', function(){
          goToSlide(dotIndex);
          startAutoplay();
        });
      });

      root.addEventListener('mouseenter', stopAutoplay);
      root.addEventListener('mouseleave', startAutoplay);

      root.querySelectorAll('.lag-coupon__copy').forEach(function(copyBtn){
        copyBtn.addEventListener('click', async function(e){
          e.preventDefault();

          var code = copyBtn.getAttribute('data-coupon-code') || '';
          var card = copyBtn.closest('.lag-coupon__card');
          var toast = card ? card.querySelector('.lag-coupon__toast') : null;

          if(!code) return;

          try{
            if(navigator.clipboard && window.isSecureContext){
              await navigator.clipboard.writeText(code);
            }else{
              var ta = document.createElement('textarea');
              ta.value = code;
              ta.setAttribute('readonly','');
              ta.style.position = 'absolute';
              ta.style.left = '-9999px';
              document.body.appendChild(ta);
              ta.select();
              document.execCommand('copy');
              document.body.removeChild(ta);
            }

            if(toast){
              toast.classList.add('is-visible');
              window.clearTimeout(toast.__t);
              toast.__t = window.setTimeout(function(){
                toast.classList.remove('is-visible');
              }, {{ section.settings.toast_duration_ms }});
            }
          }catch(err){}
        });
      });

      goToSlide(0);
      startAutoplay();
    })();
  </script>
</section>

