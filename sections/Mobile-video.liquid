{% comment %}
  Mobile Video with Shop Now Button
{% endcomment %}

<section
  id="lagorii-video-{{ section.id }}"
  class="lagorii-mobile-video-section"
>
  <div class="lagorii-video-wrapper lagorii-ratio-{{ section.settings.video_ratio }}">
    {% if section.settings.video != blank %}
      {{ section.settings.video | video_tag:
        autoplay: section.settings.autoplay,
        loop: section.settings.loop_video,
        muted: true,
        playsinline: true,
        controls: false,
        class: 'lagorii-custom-video'
      }}
    {% elsif section.settings.video_url != blank %}
      <video
        class="lagorii-custom-video"
        {% if section.settings.autoplay %}autoplay{% endif %}
        {% if section.settings.loop_video %}loop{% endif %}
        muted
        playsinline
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% else %}
      <div class="lagorii-video-placeholder">
        Add video from section settings
      </div>
    {% endif %}

    {% if section.settings.show_mute_button %}
      <button
        type="button"
        class="lagorii-mute-btn"
        aria-label="Mute or unmute video"
      >
        🔇
      </button>
    {% endif %}

    {% if section.settings.show_shop_button %}
      {% assign final_link = section.settings.button_link %}
      {% if section.settings.collection_link != blank %}
        {% assign final_link = section.settings.collection_link.url %}
      {% endif %}

      {% if final_link != blank %}
        <a href="{{ final_link }}" class="lagorii-shop-btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    {% endif %}
  </div>
</section>

<style>
  #lagorii-video-{{ section.id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    #lagorii-video-{{ section.id }} {
      display: block;
      padding-top: {{ section.settings.padding_top }}px;
      padding-right: {{ section.settings.padding_right }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: {{ section.settings.padding_left }}px;
      background: {{ section.settings.section_bg }};
    }

    #lagorii-video-{{ section.id }} .lagorii-video-wrapper {
      position: relative;
      width: 100%;
      overflow: hidden;
      border-radius: {{ section.settings.corner_radius }}px;
      background: #f5f5f5;
    }

    #lagorii-video-{{ section.id }} .lagorii-ratio-4-5 {
      aspect-ratio: 4 / 5;
    }

    #lagorii-video-{{ section.id }} .lagorii-ratio-1-1 {
      aspect-ratio: 1 / 1;
    }

    #lagorii-video-{{ section.id }} .lagorii-ratio-16-9 {
      aspect-ratio: 16 / 9;
    }

    #lagorii-video-{{ section.id }} .lagorii-custom-video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    #lagorii-video-{{ section.id }} .lagorii-video-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: {{ section.settings.font_family }};
      font-size: 14px;
      color: #777;
      background: #f2f2f2;
    }

    #lagorii-video-{{ section.id }} .lagorii-shop-btn {
      position: absolute;
      left: 50%;
      bottom: {{ section.settings.button_bottom }}px;
      transform: translateX(-50%);
      z-index: 3;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: {{ section.settings.button_width }}px;
      padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
      border-radius: {{ section.settings.button_radius }}px;
      background: {{ section.settings.button_bg }};
      color: {{ section.settings.button_text_color }};
      opacity: {{ section.settings.button_opacity | divided_by: 100.0 }};
      font-family: {{ section.settings.font_family }};
      font-size: {{ section.settings.button_font_size }}px;
      font-weight: {{ section.settings.button_font_weight }};
      line-height: 1;
      text-decoration: none;
      text-align: center;
      transition: 0.25s ease;
    }

    #lagorii-video-{{ section.id }} .lagorii-shop-btn:hover {
      opacity: 1;
    }

    #lagorii-video-{{ section.id }} .lagorii-mute-btn {
      position: absolute;
      top: {{ section.settings.mute_top }}px;
      right: {{ section.settings.mute_right }}px;
      z-index: 4;
      width: {{ section.settings.mute_size }}px;
      height: {{ section.settings.mute_size }}px;
      border-radius: 50%;
      border: none;
      background: {{ section.settings.mute_bg }};
      color: {{ section.settings.mute_color }};
      opacity: {{ section.settings.mute_opacity | divided_by: 100.0 }};
      font-size: {{ section.settings.mute_icon_size }}px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.querySelector('#lagorii-video-{{ section.id }}');
    if (!section) return;

    const video = section.querySelector('video');
    const muteBtn = section.querySelector('.lagorii-mute-btn');

    if (!video || !muteBtn) return;

    video.muted = true;
    muteBtn.textContent = '🔇';

    muteBtn.addEventListener('click', function () {
      video.muted = !video.muted;
      muteBtn.textContent = video.muted ? '🔇' : '🔊';

      if (!video.paused) return;

      video.play().catch(function () {});
    });
  });
</script>

{% schema %}
{
