    {
      "type": "text",
      "id": "wishlist_label",
      "label": "Wishlist label",
      "default": "Wishlist"
    },
    {
      "type": "checkbox",
      "id": "show_close",
      "label": "Show close button",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "always_mobile",
      "label": "Always pin to bottom on mobile (ignore scroll)",
      "default": true
    }
  ],
  "presets": [
    { "name": "Sticky Add to Cart (Mobile)" }
  ]
}
{% endschema %}
