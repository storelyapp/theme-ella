{%- comment -%}
Reset Password — Section
Keeps preview styling, uses Shopify form 'reset_customer_password'.
{%- endcomment -%}

{{ 'customer.css' | asset_url | stylesheet_tag }}

<!-- Montserrat -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">

<div class="customer reset-password login-item">
  <!-- Error icon (matches your preview) -->
  <svg style="display:none" aria-hidden="true">
    <symbol id="icon-error" viewBox="0 0 13 13">
      <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
      <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
      <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
      <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7"></path>
    </symbol>
  </svg>

  <h1 class="page-header">Create your password</h1>
  <p class="login-text">
    Enter a new password for <strong>{{ email }}</strong>.
  </p>

  {%- form 'reset_customer_password', id: 'ResetPasswordForm' -%}
    {%- if form.errors -%}
      <div class="form__message" tabindex="-1" autofocus>
        <svg aria-hidden="true" focusable="false" role="presentation"><use href="#icon-error"/></svg>
        <div>
          <strong>{{ 'templates.contact.form.error_heading' | t }}</strong>
          <ul class="form-error-list">
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  <a href="#{{ field }}">
                    {{ form.errors.translated_fields[field] | capitalize }}
                    {{ form.errors.messages[field] }}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    {%- endif -%}

    <div class="form-field">
      <label for="password" class="form-label">New password</label>
      <input
        type="password"
        name="customer[password]"
        id="password"
        class="form-input form-input-placeholder"
        autocomplete="new-password"
        placeholder="New password"
        {% if form.errors contains 'password' %} aria-invalid="true" aria-describedby="password-error"{% endif %}
        required
      >
      <small id="note-reset-password" class="auth-pass-note" hidden></small>

      {%- if form.errors contains 'password' -%}
        <small id="password-error" class="form__message">
          <svg aria-hidden="true" focusable="false" role="presentation"><use href="#icon-error"/></svg>
          {{ form.errors.translated_fields['password'] | capitalize }} {{ form.errors.messages['password'] }}
        </small>
      {%- endif -%}
    </div>

    <div class="form-field">
      <label for="password_confirmation" class="form-label">Confirm new password</label>
      <input
        type="password"
        class="form-input form-input-placeholder"
        name="customer[password_confirmation]"
        id="password_confirmation"
        autocomplete="new-password"
        placeholder="Confirm new password"
        {% if form.errors contains 'password_confirmation' %} aria-invalid="true" aria-describedby="password_confirmation-error"{% endif %}
        required
      >

      <small id="note-reset-password-confirm" class="auth-pass-note" hidden></small>
      
      {%- if form.errors contains 'password_confirmation' -%}
        <small id="password_confirmation-error" class="form__message">
          <svg aria-hidden="true" focusable="false" role="presentation"><use href="#icon-error"/></svg>
          {{ form.errors.translated_fields['password_confirmation'] | capitalize }} {{ form.errors.messages['password_confirmation'] }}
        </small>
      {%- endif -%}
    </div>

    <button class="button button-2" type="submit">Submit</button>
  {%- endform -%}
</div>

<style>
  :root{
    --brand:#E87529; --ink:#111; --muted:#666; --bg:#FAFAFA; --radius:20px;
    /* match login/register sizing */
    --auth-font:16px;   /* inputs & button */
    --auth-label:15px;  /* labels */
  }
  *{ box-sizing:border-box }

  .customer.reset-password.login-item{
    width:min(560px,94vw);
    background:#fff;
    border-radius:var(--radius);
    box-shadow:0 10px 34px rgba(0,0,0,.08);
    padding:22px;
    font-family:"Montserrat",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  }

  .page-header{ margin:4px 0 10px; font-size:1.55rem; font-weight:800; text-align:center; color:var(--ink); }
  .login-text{ margin:0 0 16px; color:#333; text-align:center; }

  /* Error container */
  .form__message{
    display:flex; align-items:flex-start; gap:8px;
    background:#fde7e7; color:#8e2f2f; border:1px solid #f3c7c7;
    border-radius:12px; padding:12px 14px; margin:10px 0 14px;
    font-weight:600;
  }
  .form__message svg{ width:16px; height:16px; flex:0 0 16px; margin-top:2px; }

  /* Remove bullets & spacing in error list */
  .form-error-list{ list-style:none; margin:8px 0 0; padding:0; }
  .form-error-list li{ margin:0; padding:0; }

  .form-field{ display:grid; gap:6px; margin-bottom:14px; }
  .form-label{ font-size:var(--auth-label); font-weight:600; color:#333; }
  .form-input{
    width:100%; height:52px; padding:12px 14px;
    border:1px solid #E6E6EA; border-radius:16px;
    background:#fff; font-size:var(--auth-font);
  }
  .form-input:focus{ outline:none; border-color:var(--brand); box-shadow:0 0 0 3px rgba(232,117,41,.18); }

  .button.button-2{
    width:100%; height:52px; border:0; border-radius:16px;
    background:var(--brand); color:#fff; font-weight:800; font-size:var(--auth-font); cursor:pointer;
    transition:filter .2s;
  }
  .button.button-2:hover{ filter:brightness(.96); }

  small.form__message{
    display:flex; align-items:center; gap:8px;
    background:#fde7e7; color:#8e2f2f; border:0; box-shadow:none;
    padding:8px 10px; border-radius:10px; margin-top:6px;
    font-weight:600; font-size:0.9rem;
  }

  @media (min-width:768px){ .customer.reset-password.login-item{ padding:26px; } }

  .auth-pass-note{
  margin-top:6px;
  font-size:.85rem;
  color:#666;
  font-weight:600;
  word-break:break-word;
}
.auth-pass-note[hidden]{ display:none !important; }

</style>

<script>
  (function(){
    function hookPassPreview(inputId, noteId, label){
      const el = document.getElementById(inputId);
      const note = document.getElementById(noteId);
      if(!el || !note) return;
      const update = () => {
        const v = el.value || '';
        if (v.length){
          note.hidden = false;
          note.textContent = (label || 'Password') + ': ' + v;
        } else {
          note.hidden = true;
          note.textContent = '';
        }
      };
      el.addEventListener('input', update);
      el.addEventListener('change', update);
      update();
    }

    hookPassPreview('password','note-reset-password','New password');
    hookPassPreview('password_confirmation','note-reset-password-confirm','Confirm password');
  })();
</script>

{% schema %}
{
  "name": "Reset Password UI",
  "settings": []
}
{% endschema %}
