    <script>
    (function () {
      // -------- Cart Count Sync (single source of truth) --------
      const CACHE_KEY = 'lag_cart_count_v1';
      const CACHE_TTL = 8000; // ms (fast enough for UX, light enough for performance)

      function getTargets() {
        return {
          headerCounts: Array.from(document.querySelectorAll('[data-cart-count]')),
          badges: Array.from(document.querySelectorAll('[data-cart-badge]'))
        };
      }

      function applyCount(count) {
        const n = Number(count) || 0;
        const { headerCounts, badges } = getTargets();

        headerCounts.forEach(el => { el.textContent = String(n); });

        badges.forEach(el => {
          el.textContent = String(n);
          el.style.display = n > 0 ? 'inline-block' : 'none';
        });
      }

      function readCache() {
        try {
          const raw = sessionStorage.getItem(CACHE_KEY);
          if (!raw) return null;
          const obj = JSON.parse(raw);
          if (!obj || (Date.now() - obj.t) > CACHE_TTL) return null;
          return obj.c;
        } catch (_) { return null; }
      }

      function writeCache(count) {
        try {
          sessionStorage.setItem(CACHE_KEY, JSON.stringify({ c: Number(count) || 0, t: Date.now() }));
        } catch (_) {}
      }

      async function fetchCartCount() {
        const res = await fetch('/cart.js', {
          credentials: 'same-origin',
          headers: { 'Accept': 'application/json' }
        });
        if (!res.ok) throw new Error('cart.js failed');
        const cart = await res.json();
        return Number(cart.item_count) || 0;
      }

      let inFlight = null;
      async function refreshCount({ force = false } = {}) {
        const cached = readCache();
        if (!force && cached !== null) {
          applyCount(cached);
          // SWR: refresh in idle so it stays accurate
          if ('requestIdleCallback' in window) {
            requestIdleCallback(() => refreshCount({ force: true }), { timeout: 1500 });
          } else {
            setTimeout(() => refreshCount({ force: true }), 0);
          }
          return cached;
        }

        if (inFlight) return inFlight;

        inFlight = (async () => {
          try {
            const c = await fetchCartCount();
            writeCache(c);
            applyCount(c);
            return c;
          } finally {
            inFlight = null;
          }
        })();

        return inFlight;
      }

      // Initial paint
      refreshCount();

      // Listen to your existing custom events (keep compatibility)
      ['cart:refresh','cart:updated','ajaxProduct:added','quantity:change','lineItem:remove'].forEach(evt => {
        document.addEventListener(evt, () => refreshCount({ force: true }), { passive: true });
      });

      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') refreshCount({ force: true });
      }, { passive: true });

      window.addEventListener('pageshow', (e) => {
        if (e.persisted) refreshCount({ force: true });
      }, { passive: true });

      // ---- Auto-detect Shopify cart mutations via fetch() interception ----
      const CART_MUTATION_RE = /\/cart\/(add|change|update|clear)\.js(\?|$)/i;
      const _fetch = window.fetch;
      if (typeof _fetch === 'function') {
        window.fetch = function(input, init) {
          const url = (typeof input === 'string') ? input : (input && input.url) || '';
          const isCartMutation = CART_MUTATION_RE.test(url);

          return _fetch.apply(this, arguments).then(async (res) => {
            if (isCartMutation) {
              // Let Shopify update settle, then refresh once
              try { document.dispatchEvent(new Event('cart:updated')); } catch(_) {}
              // force refresh (don’t rely on cache)
              refreshCount({ force: true });
            }
            return res;
          });
        };
      }

      // Optional: expose manual trigger
      window.LAG_refreshCartCount = refreshCount;
    })();
    </script>
  </body>
</html>