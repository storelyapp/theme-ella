    <script>
      (function(){
        function injectLagoriiNowBadges(){
          try {
            var tpl = document.getElementById('lagorii-now-badge-template');
            if (!tpl || !tpl.content || !tpl.content.firstElementChild) {
              return;
            }

            var cards = document.querySelectorAll(
              '.product-item .card-product__wrapper, .product-item.usf-card-6 .card-product__wrapper'
            );

            cards.forEach(function (wrapper) {
              if (!wrapper) return;
              // prevent duplicates
              if (wrapper.querySelector('.lagorii-now-badge')) return;

              var clone = tpl.content.firstElementChild.cloneNode(true);
              var firstChild = wrapper.firstElementChild;
              if (firstChild) wrapper.insertBefore(clone, firstChild);
              else wrapper.appendChild(clone);
            });
          } catch (e) {
            console.error('LagoriiNowBadge error:', e);
          }
        }

        function initLagoriiNow(){
          // run once immediately
          injectLagoriiNowBadges();

          // then watch for grid changes (filters, infinite scroll, theme JS, etc.)
          try {
            if (window.__LAG_NOW_OBS) return; // singleton guard
            var mo = new MutationObserver(function(muts){
              // debounced-ish: just reinject on any DOM change
              injectLagoriiNowBadges();
            });
            mo.observe(document.body, { childList: true, subtree: true });
            window.__LAG_NOW_OBS = mo;
          } catch (e) {
            console.warn('LagoriiNowBadge: observer failed', e);
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initLagoriiNow);
        } else {
          initLagoriiNow();
        }
      })();
    </script>
